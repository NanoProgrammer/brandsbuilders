---
import Layout from '../layouts/Layout.astro';
const seo = { title: 'Page Not Found — BrandsBuilders', description: 'This page does not exist.' };
---
<Layout seo={seo}>
<section class="bg-white min-h-[70vh] flex items-center">
  <div class="container mx-auto px-6 max-w-2xl text-center py-20">
    <p class="text-sm text-gray-500 uppercase tracking-wider mb-4">404 — Not Found</p>
    <h1 class="text-4xl font-bold text-gray-900 mb-4">This page doesn't exist</h1>
    <p class="text-lg text-gray-600 mb-8">The link may be outdated, or the page was removed.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="px-8 py-3.5 rounded-lg font-semibold text-white bg-orange-600 hover:bg-orange-700 transition">Go to homepage →</a>
      <a href="/apply" class="px-8 py-3.5 rounded-lg font-semibold text-gray-700 border border-gray-300 hover:border-gray-400 transition">Apply now</a>
    </div>
  </div>
</section>
</Layout>

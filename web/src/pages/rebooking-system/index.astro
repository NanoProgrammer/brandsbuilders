---
import Layout from '../../layouts/Layout.astro';
const seo = { title: 'Revenue Efficiency System | BrandsBuilders', description: 'Missed-call protection, show-up optimization, and client reactivation for home services businesses.', canonical: 'https://brandsbuilders.ca/rebooking-system' };
---
<Layout seo={seo}>
<section class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-4xl">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Revenue Efficiency System</h1>
    <p class="text-lg text-gray-600 mb-8">We install a missed-call and lead conversion system that turns more inbound leads into booked jobs — live in 2 weeks.</p>
    <div class="space-y-6 text-gray-600 text-lg leading-relaxed">
      <p><strong class="text-gray-900">Lever 1 — Missed-Call Protection:</strong> Instant SMS within seconds of a missed call. Captures and converts missed calls directly into your calendar. 24/7.</p>
      <p><strong class="text-gray-900">Lever 2 — Show-Up Optimization:</strong> Pre-appointment emails + SMS reminders at 24h and 2h before each job. Reduce no-shows by up to 33%.</p>
      <p><strong class="text-gray-900">Bonus — Past Client Reactivation:</strong> One-time outreach to your past client list via email and SMS with a small free offer to get them back through the door.</p>
    </div>
    <div class="mt-10 bg-gray-900 text-white rounded-xl p-8 text-center">
      <div class="text-4xl font-bold mb-2">$1,000<span class="text-xl font-normal text-gray-400">/mo</span></div>
      <p class="text-gray-400 mb-4">Monthly reporting included. 5 recovered leads in 30 days or money back.</p>
      <a href="/apply" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">Check If You Qualify →</a>
    </div>
  </div>
</section>
</Layout>
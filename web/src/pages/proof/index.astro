---
import Layout from '../../layouts/Layout.astro';

const seo = {
  title: 'Proof of Work — BrandsBuilders | Websites, Results & Reviews',
  description: 'Real projects and real Google reviews from home service and trades businesses. See the websites we\'ve built and what clients say about working with BrandsBuilders.',
  canonical: 'https://brandsbuilders.ca/proof'
};

const websites = [
  {
    name: 'Refresh Exteriors',
    industry: 'Window Cleaning & Snow Removal · Calgary',
    url: 'https://refreshedexterior.com',
    image: '/images/portfolio/refresh-exteriors.png',
    work: 'Website rebuild',
    result: 'Conversion-focused design, mobile-first layout. First new customer within 7 days of launch.'
  },
  {
    name: 'GrillsGuard',
    industry: 'Home Service · Calgary',
    url: 'https://grillsguard.com',
    image: '/proof/grillsguard-hero-768.webp',
    work: 'Full website build',
    result: 'Fast, service-focused site built to turn visitors into quote requests.'
  },
  {
    name: 'Kelly & Sons YYC',
    industry: 'Local Service Business · Calgary',
    url: 'https://kellyandsonsyyc.ca',
    image: '/images/portfolio/kellyandsons.png',
    work: 'Website build',
    result: 'Professional local service site generating calls and quote requests.'
  },
  {
    name: 'Artilate',
    industry: 'Handcrafted Colombian Chocolate · Calgary',
    url: 'https://artilate.com',
    image: '/images/portfolio/artilate.png',
    work: 'E-commerce website',
    result: 'Conversion-focused product pages with brand storytelling and clean checkout.'
  },
  {
    name: 'Gaplets',
    industry: 'Scheduling SaaS',
    url: 'https://gaplets.com',
    image: '/proof/gaplets-hero-768.webp',
    work: 'SaaS marketing site',
    result: 'Landing page explaining the product clearly and driving free trial signups.'
  },
  {
    name: 'Brain Freeze Fruit',
    industry: 'Natural Freezies & Latin Foods · Calgary',
    url: 'https://behealthyhappy.ca',
    image: '/images/portfolio/behealthyhappy.png',
    work: 'Brand + website',
    result: 'E-commerce store with product listings, brand identity, and mobile shopping experience.'
  },
  {
    name: 'Vaulted YYC',
    industry: 'Retro Games & Pokémon · Calgary',
    url: null,
    image: '/images/portfolio/vaulted.png',
    work: 'Retail website',
    result: 'Product catalog and brand site for a collectibles shop.'
  },
  {
    name: 'Bavarian Nuts YYC',
    industry: 'Roasted Nuts & Snacks · Calgary',
    url: null,
    image: '/images/portfolio/bavarian-nuts.png',
    work: 'Brand + website',
    result: 'E-commerce presence for a small food vendor expanding online.'
  },
];

const reviews = [
  { name: 'Heaven Artisan GF', tag: 'Local Guide', text: "I've had the chance to work with this young professional, and I can confidently say he's the real deal. He actually listens, understands the day-to-day challenges we face, and delivers solutions that are practical, efficient, and tailored — not generic. He doesn't just talk strategy, he executes." },
  { name: 'Abdul B.', tag: 'Local Guide', text: 'Great developer, straightforward. Clean layout and helped increase revenue for my business.' },
  { name: 'Jordan', tag: 'Local Guide', text: 'Was great working with Santiago. Would absolutely recommend 100%.' },
  { name: 'Sofia Gonzalez', text: 'Great experience! Very professional, fast, and delivered exactly what I wanted. The website looks amazing and works perfectly.' },
  { name: 'Justice Rayy', text: 'Local, friendly, and brings results over the expectation. Highly recommended.' },
  { name: 'Fabian Aguilar', text: "I didn't have too much expectations at first, but the outcome was amazing — great webpage and quick quality results." },
  { name: 'Igor Rupyshev', tag: 'Local Guide', text: 'Built me an amazing website. 100% recommended.' },
  { name: 'Abby', text: 'Great website.' },
];
---

<Layout seo={seo}>

  <!-- Header -->
  <section class="bg-white py-16 border-b border-gray-200">
    <div class="container mx-auto px-6 max-w-5xl">
      <p class="text-sm text-orange-600 font-semibold uppercase tracking-wider mb-3">Proof of Work</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight max-w-3xl mb-5">
        Real projects. Real clients.
      </h1>
      <p class="text-lg text-gray-600 max-w-2xl leading-relaxed mb-8">
        This isn't a portfolio for aesthetics — it's evidence that we know how to build things that work for service businesses like yours.
      </p>
      <a href="/apply" class="inline-flex px-7 py-3.5 rounded-lg font-semibold text-white bg-gray-900 hover:bg-gray-800 transition">
        See if I qualify for the program →
      </a>
    </div>
  </section>

  <!-- ═══ WEBSITES ═══ -->
  <section class="bg-white py-20">
    <div class="container mx-auto px-6 max-w-5xl">

      <div class="flex items-center gap-3 mb-12">
        <div class="w-8 h-8 rounded-lg bg-orange-100 text-orange-600 flex items-center justify-center font-bold text-sm">1</div>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Websites</h2>
        <span class="text-sm text-gray-400">10+ projects</span>
      </div>

      <div class="grid sm:grid-cols-2 gap-8">
        {websites.map((p) => (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md hover:border-gray-300 transition">
            <div class="aspect-[16/10] overflow-hidden bg-gray-100">
              <img src={p.image} alt={p.name} loading="lazy" class="w-full h-full object-cover object-top" />
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <p class="font-bold text-gray-900 text-lg">{p.name}</p>
                <span class="shrink-0 text-xs font-medium text-gray-600 bg-gray-100 border border-gray-200 px-2.5 py-1 rounded-full">{p.work}</span>
              </div>
              <p class="text-sm text-gray-500 mb-3">{p.industry}</p>
              <p class="text-sm text-gray-600 leading-relaxed">{p.result}</p>
              {p.url && (
                <a href={p.url} target="_blank" rel="noopener noreferrer"
                  class="inline-block mt-4 text-sm font-medium text-orange-600 hover:text-orange-700 transition">
                  Visit site →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ SYSTEM RESULTS ═══ -->
  <section class="bg-gray-50 py-20 border-y border-gray-200">
    <div class="container mx-auto px-6 max-w-5xl">

      <div class="flex items-center gap-3 mb-12">
        <div class="w-8 h-8 rounded-lg bg-orange-100 text-orange-600 flex items-center justify-center font-bold text-sm">2</div>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Revenue Recovery + Growth</h2>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl p-8 max-w-2xl">
        <div class="flex items-start gap-4 mb-5">
          <div class="w-10 h-10 rounded-full bg-orange-50 text-orange-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Onboarding first clients now</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Results from the recovery + growth system will be published here with real metrics: calls recovered, jobs booked, revenue reactivated. Honest beats manufactured.
            </p>
          </div>
        </div>
        <a href="/apply" class="inline-flex px-6 py-3 rounded-lg font-semibold text-white bg-orange-600 hover:bg-orange-700 transition text-sm">
          Be one of the first →
        </a>
      </div>

    </div>
  </section>

  <!-- ═══ GOOGLE REVIEWS ═══ -->
  <section class="bg-white py-20">
    <div class="container mx-auto px-6 max-w-5xl">

      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 rounded-lg bg-yellow-100 text-yellow-600 flex items-center justify-center font-bold text-sm">3</div>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Google Reviews</h2>
      </div>
      <p class="text-gray-500 mb-12 ml-11 text-sm">Verified reviews — not stock testimonials.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {reviews.map((r) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-5 flex flex-col">
            <div class="flex gap-0.5 text-yellow-400 mb-3">
              {Array.from({length: 5}).map(() => (
                <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.802 2.035a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.802-2.035a1 1 0 00-1.175 0L6.62 16.282c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.984 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-gray-700 text-sm leading-relaxed flex-1">"{r.text}"</p>
            <div class="mt-4 pt-3 border-t border-gray-200">
              <p class="font-semibold text-gray-900 text-sm">{r.name}</p>
              {r.tag && <p class="text-xs text-gray-500">{r.tag} · Google</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-900 text-white py-16 text-center">
    <div class="container mx-auto px-6 max-w-2xl">
      <h2 class="text-2xl sm:text-3xl font-bold mb-3">Ready to see real results in your business?</h2>
      <p class="text-gray-400 mb-8">Apply now — 1 spot available this week.</p>
      <a href="/apply" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">
        Apply to the program →
      </a>
    </div>
  </section>

</Layout>

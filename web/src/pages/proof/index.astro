---
import Layout from '../../layouts/Layout.astro';
const seo = { title: 'Our Work — BrandsBuilders', description: 'Real projects built for real businesses.', canonical: 'https://brandsbuilders.ca/proof' };
const projects = [
  { name: 'Refresh Exteriors', stack: 'Window Cleaning & Snow Removal · Calgary', url: 'https://refreshedexterior.com', image: '/images/portfolio/refresh-exteriors.png' },
  { name: 'Artilate', stack: 'Handcrafted Colombian Chocolate · Calgary', url: 'https://artilate.com', image: '/images/portfolio/artilate.png' },
  { name: 'GrillsGuard', stack: 'Service · Calgary', url: 'https://grillsguard.com', image: '/proof/grillsguard-hero-768.webp' },
  { name: 'Gaplets', stack: 'Scheduling SaaS', url: 'https://gaplets.com', image: '/proof/gaplets-hero-768.webp' },
  { name: 'Brain Freeze Fruit', stack: 'Natural Freezies & Latin Foods · Calgary', url: 'https://behealthyhappy.ca', image: '/images/portfolio/behealthyhappy.png' },
  { name: 'Kelly & Sons YYC', stack: 'Local Service Business · Calgary', url: 'https://kellyandsonsyyc.ca', image: '/images/portfolio/kellyandsons.png' },
  { name: 'Vaulted YYC', stack: 'Retro Games & Pokémon · Calgary', url: null, image: '/images/portfolio/vaulted.png' },
  { name: 'Bavarian Nuts YYC', stack: 'Roasted Nuts & Snacks · Calgary', url: null, image: '/images/portfolio/bavarian-nuts.png' },
];
---
<Layout seo={seo}>
<section class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-5xl">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Real projects. Real businesses.</h1>
    <p class="text-lg text-gray-600 mb-14">Every site built from scratch for a real local business.</p>
    <div class="grid sm:grid-cols-2 gap-8">
      {projects.map((p) => (
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md transition">
          <div class="aspect-[16/10] overflow-hidden"><img src={p.image} alt={p.name} loading="lazy" class="w-full h-full object-cover object-top" /></div>
          <div class="p-5">
            <p class="font-semibold text-gray-900">{p.name}</p>
            <p class="text-sm text-gray-500 mt-1">{p.stack}</p>
            {p.url && <a href={p.url} target="_blank" rel="noopener noreferrer" class="inline-block mt-3 text-sm font-medium text-orange-600 hover:text-orange-700">Visit site →</a>}
          </div>
        </div>
      ))}
    </div>
    <div class="mt-14 text-center">
      <a href="/apply" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-white bg-orange-600 hover:bg-orange-700 transition">Get Started →</a>
    </div>
  </div>
</section>
</Layout>

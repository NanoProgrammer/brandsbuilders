---
import Layout from '../../layouts/Layout.astro';

const seo = {
  title: 'Our Work — Calgary Business Websites | BrandsBuilders',
  description:
    'Real websites built for real Calgary businesses. See the portfolio — from service companies to food brands to retail stores.',
  canonical: 'https://brandsbuilders.ca/proof'
};

/* ── FEATURED (case-study format) ── */
const featured = [
  {
    name: 'Refresh Exteriors',
    url: 'https://refreshedexterior.com',
    label: 'Visit site',
    stack: 'Window Cleaning & Snow Removal · Calgary, AB',
    hero: '/images/portfolio/refresh-exteriors.png',
    problem:
      'No online presence to capture the growing number of people searching Google for window cleaning and snow removal in Calgary.',
    change:
      'Built a custom multi-page website with service breakdowns, a booking flow, and on-page SEO targeting Calgary-specific searches.',
    result:
      'A professional site that shows up on Google, builds instant trust, and turns visitors into booked jobs.'
  },
  {
    name: 'Artilate',
    url: 'https://artilate.com',
    label: 'Visit site',
    stack: 'Handcrafted Colombian Chocolate · Calgary & Area',
    hero: '/images/portfolio/artilate.png',
    problem:
      'The brand needed a stronger digital presence to support product discovery, build trust, and drive repeat buying.',
    change:
      'Designed a polished brand website with premium presentation, clear navigation, and a story-driven layout that reflects the craft behind the product.',
    result:
      'A more professional storefront that elevates brand perception and supports long-term growth.'
  }
];

/* ── GRID (simpler portfolio cards) ── */
const grid = [
  {
    name: 'Brain Freeze Fruit',
    stack: 'Natural Freezies & Latin Foods · Calgary',
    url: 'https://behealthyhappy.ca',
    image: '/images/portfolio/behealthyhappy.png'
  },
  {
    name: 'Kelly & Sons YYC',
    stack: 'Local Service Business · Calgary',
    url: 'https://kellyandsonsyyc.ca',
    image: '/images/portfolio/kellyandsons.png'
  },
  {
    name: 'Vaulted YYC',
    stack: 'Retro Games & Pokémon · Calgary',
    url: null,
    image: '/images/portfolio/vaulted.png'
  },
  {
    name: 'Bavarian Nuts YYC',
    stack: 'Roasted Nuts & Snacks · Calgary',
    url: null,
    image: '/images/portfolio/bavarian-nuts.png'
  }
];

const signals = [
  'Real business websites built with clear positioning',
  'Portfolio pieces tied to real business use cases',
  'Conversion-focused structure, not just visual design',
  'Brand, service, and retail projects in one portfolio',
  'Built to support trust, bookings, and growth',
  'Done-for-you implementation — not DIY templates'
];
---

<Layout seo={seo}>

  <!-- HERO -->
  <section class="relative bg-slate-950 text-white pt-16 pb-24 overflow-hidden border-b border-slate-800">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-slate-950 to-fuchsia-950/35"></div>

    <div class="relative container mx-auto px-6 max-w-6xl reveal">
      <p class="text-sm uppercase tracking-[0.2em] text-slate-400 mb-6">
        Selected Work
      </p>

      <h1 class="text-5xl lg:text-6xl font-semibold leading-[1.05] max-w-5xl">
        Real projects.
        <span class="text-fuchsia-300">Real businesses.</span>
        Real websites & systems.
      </h1>

      <p class="mt-7 text-xl text-slate-300 leading-relaxed max-w-3xl">
        Every site here was built from scratch for a real local business —
        no templates, no page builders, no fluff.
      </p>

      <div class="mt-10 flex gap-4 flex-wrap">
        <a
          href="#projects"
          class="inline-flex items-center justify-center px-10 py-4 rounded-xl font-semibold
                 bg-white text-slate-950 hover:bg-slate-200 transition"
        >
          View projects ↓
        </a>

        <a
          href="/apply"
          class="inline-flex items-center justify-center px-10 py-4 rounded-xl font-semibold
                 bg-gradient-to-r from-orange-500 via-pink-500 to-fuchsia-600
                 text-white hover:opacity-90 transition"
        >
          Check qualification →
        </a>
      </div>

      <div class="mt-14 grid sm:grid-cols-3 gap-4 max-w-4xl">
        {[...featured, grid[0]].map((c) => (
          <a
            href={c.url}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 hover:border-fuchsia-400/40 hover:bg-slate-900 transition"
          >
            <p class="text-white font-medium">{c.name}</p>
            <p class="text-sm text-slate-400 mt-2">{c.stack}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED CASE STUDIES -->
  <section id="projects" class="bg-slate-950 py-28">
    <div class="container mx-auto px-6 max-w-6xl space-y-24">
      {featured.map((c, idx) => (
        <article class="reveal grid lg:grid-cols-12 gap-12 items-start">

          <!-- META -->
          <div class={`lg:col-span-4 lg:sticky lg:top-24 ${idx % 2 !== 0 ? 'lg:order-2' : ''}`}>
            <p class="text-sm uppercase tracking-widest text-slate-400">{c.name}</p>
            <p class="text-slate-500 text-sm mt-2">{c.stack}</p>

            <div class="mt-8 space-y-4">
              <p class="text-slate-300">
                <span class="text-slate-500">Challenge — </span>{c.problem}
              </p>
              <p class="text-slate-300">
                <span class="text-slate-500">Built — </span>{c.change}
              </p>
              <p class="text-white font-medium">
                <span class="text-slate-500">Outcome — </span>{c.result}
              </p>
            </div>

            <div class="mt-8 flex flex-wrap gap-3">
              <a
                href={c.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold
                       bg-white text-slate-950 hover:bg-slate-200 transition"
              >
                {c.label} ↗
              </a>

              <a
                href="/apply"
                class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold
                       border border-slate-700 text-slate-200 hover:border-slate-500 hover:bg-slate-900 transition"
              >
                Work with me
              </a>
            </div>

            <p class="mt-4 text-sm text-slate-500 break-all">
              {c.url}
            </p>
          </div>

          <!-- VISUALS -->
          <div class={`lg:col-span-8 space-y-6 ${idx % 2 !== 0 ? 'lg:order-1' : ''}`}>
            <div class="rounded-2xl overflow-hidden border border-slate-800 bg-slate-900 shadow-2xl">
              <img
                src={c.hero}
                alt={`${c.name} website preview`}
                loading={idx === 0 ? 'eager' : 'lazy'}
                class="w-full object-cover"
              />
            </div>
          </div>

        </article>
      ))}
    </div>
  </section>

  <!-- PORTFOLIO GRID -->
  <section class="bg-slate-950 py-24 border-t border-slate-800">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="mb-12 reveal">
        <p class="text-sm uppercase tracking-widest text-slate-400">More work</p>
        <h2 class="mt-3 text-3xl font-semibold text-white max-w-3xl">
          Same quality. <span class="text-fuchsia-300">Every project.</span>
        </h2>
      </div>

      <div class="reveal grid sm:grid-cols-2 gap-6">
        {grid.map((p) => (
          <div class="group rounded-2xl border border-slate-800 bg-slate-900/40 overflow-hidden
                      hover:border-fuchsia-400/30 hover:bg-slate-900/60 transition">
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={p.image}
                alt={`${p.name} website`}
                loading="lazy"
                class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-500"
              />
            </div>
            <div class="p-5">
              <p class="text-white font-medium">{p.name}</p>
              <p class="text-sm text-slate-400 mt-1">{p.stack}</p>
              {p.url && (
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block mt-3 text-sm font-semibold text-fuchsia-400 hover:text-white transition"
                >
                  Visit site →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SIGNALS -->
  <section class="bg-slate-950 py-24 border-t border-slate-800">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="mb-10 reveal">
        <p class="text-sm uppercase tracking-widest text-slate-400">What these projects show</p>
        <h2 class="mt-3 text-3xl font-semibold text-white max-w-3xl">
          Not just design — positioning, structure, and conversion thinking.
        </h2>
      </div>

      <div class="reveal grid md:grid-cols-2 gap-6">
        {signals.map((s) => (
          <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-6">
            <p class="text-slate-300 text-lg">
              <span class="text-fuchsia-300">✓</span> {s}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-slate-950 py-28 border-t border-slate-800 text-center">
    <div class="container mx-auto px-6 max-w-4xl reveal">
      <h2 class="text-3xl font-semibold text-white">
        Need a website like these for your business?
      </h2>

      <p class="mt-5 text-slate-300 text-lg max-w-2xl mx-auto">
        Custom-built websites designed to improve trust,
        presentation, and lead flow. No templates.
      </p>

      <div class="mt-10 flex justify-center gap-4 flex-wrap">
        <a
          href="/apply"
          class="inline-flex items-center justify-center px-10 py-4 rounded-xl font-semibold
                 bg-gradient-to-r from-orange-500 via-pink-500 to-fuchsia-600
                 text-white hover:opacity-90 transition"
        >
          Check qualification →
        </a>

        <a
          href="#projects"
          class="inline-flex items-center justify-center px-10 py-4 rounded-xl font-semibold
                 border border-slate-700 text-slate-200 hover:border-slate-500 hover:bg-slate-900 transition"
        >
          Browse projects
        </a>
      </div>

      <p class="mt-6 text-sm text-slate-400">
        Custom-built. No generic templates.
      </p>
    </div>
  </section>

</Layout>
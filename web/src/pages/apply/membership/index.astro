---
import Layout from '../../../layouts/Layout.astro';

const seo = {
  title: 'Full-Service Growth Membership for Home Service Businesses — $1,800/mo | BrandsBuilders',
  description: 'Ads, website CRO, missed-call recovery, quarterly reactivation + monthly reporting — all done for you. $1,800/mo. Cancel anytime with 2 weeks notice. 1 new client per week.',
  canonical: 'https://brandsbuilders.ca/apply/membership',
};

const roadmap = [
  { phase: 'Week 1', headline: 'Know exactly what\'s broken — and your real numbers.', detail: 'Audit your Ads, website, and funnel. Review unit economics (margin, close rate, cost per acquisition). Define your lead magnet.' },
  { phase: 'Week 2', headline: 'Your site converts. Every sale is tracked.', detail: 'Website CRO + end-to-end analytics with full sales tracking.' },
  { phase: 'Week 3', headline: 'Campaign live. First qualified leads coming in.', detail: 'Full campaign setup + creatives + launch.' },
  { phase: 'Weeks 4–8', headline: 'Landing page and creatives improving week over week.', detail: 'Continuous optimization + monthly creative rotation.' },
  { phase: 'Month 1', headline: 'Early signal — no sales conclusions yet.', detail: 'Progress reporting: CTR, cost per lead, impressions.' },
  { phase: 'Month 2', headline: 'Real ROI data vs. your week-1 baseline.', detail: 'Sales results reporting — 6+ weeks of real data.' },
  { phase: 'Month 3', headline: 'Scale what\'s working — without risking what is.', detail: 'Budget scaling based on your week-1 unit economics.' },
  { phase: 'Post-Quarter 1', headline: 'A custom action plan built on 3 months of your real data.', detail: 'New plan: what channels work, what creatives convert, what ICP responds best.' },
];
---

<Layout seo={seo}>

<section class="bg-white py-14 border-b border-gray-200">
  <div class="container mx-auto px-6 max-w-4xl text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm font-semibold mb-6">
      Membership — Revenue Recovery + Growth
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight max-w-3xl mx-auto">
      Everything you need to grow — one person, one fee, one report.
    </h1>
    <p class="mt-5 text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
      <strong class="text-gray-800">$1,800/mo.</strong> Ads, website CRO, missed-call protection, quarterly reactivation, and monthly reporting — run as one system.
    </p>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#apply-form"
        class="inline-flex px-8 py-4 rounded-lg font-semibold text-white bg-emerald-600 hover:bg-emerald-700 transition text-lg">
        Apply for Membership →
      </a>
      <a href="https://cal.com/brandsbuilders/30-min" target="_blank" rel="noopener noreferrer"
        class="inline-flex px-8 py-4 rounded-lg font-semibold text-gray-700 border border-gray-300 hover:border-gray-400 transition text-lg">
        Book a Fit Call
      </a>
    </div>

    <div class="mt-5 inline-flex items-center gap-2 text-sm text-amber-700 bg-amber-50 border border-amber-200 px-4 py-2 rounded-lg">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      I only take 1 new client per week. If spots are full, I'll add you to the waitlist for the following week.
    </div>
  </div>
</section>

<!-- What's included -->
<section class="bg-gray-50 py-16 border-b border-gray-200">
  <div class="container mx-auto px-6 max-w-5xl">
    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 text-center mb-12">What's included every month</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">

      {[
        { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', label: 'Ads Management', desc: 'Google or Meta — campaigns, targeting, copy, and creative testing run for you.' },
        { icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', label: 'Website CRO', desc: 'Ongoing optimization of your landing page to improve conversion rate week over week.' },
        { icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', label: 'Missed-Call Protection', desc: 'Auto-text fires within 60 seconds of every missed call, 24/7.' },
        { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', label: 'Quarterly Reactivation', desc: 'Every quarter we run a reactivation campaign on your inactive customer list.' },
        { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', label: 'Monthly Reporting', desc: 'Leads, cost per lead, source, conversions — in plain numbers every month.' },
        { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', label: 'Cancel Anytime', desc: '2 weeks notice before your next billing cycle. No penalties, no paperwork.' },
      ].map(item => (
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">{item.label}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}

    </div>
  </div>
</section>

<!-- Roadmap -->
<section class="bg-white py-16 border-b border-gray-200">
  <div class="container mx-auto px-6 max-w-4xl">
    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">What the first 90 days look like</h2>
    <p class="text-gray-600 mb-10">Your time invested: ~3 hours at setup, then 1 hour per month.</p>

    <div class="space-y-0">
      {roadmap.map((row, i) => (
        <div class={`flex gap-6 pb-8 ${i < roadmap.length - 1 ? 'border-l-2 border-gray-200 ml-5 pl-8 relative' : 'ml-5 pl-8 relative'}`}>
          <div class="absolute -left-3 top-0 w-6 h-6 rounded-full bg-emerald-600 text-white flex items-center justify-center text-xs font-bold shrink-0">{i + 1}</div>
          <div>
            <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wider mb-0.5">{row.phase}</p>
            <p class="font-bold text-gray-900 mb-1">{row.headline}</p>
            <p class="text-gray-600 text-sm leading-relaxed">{row.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Apply form -->
<section id="apply-form" class="bg-gray-50 py-16 border-b border-gray-200">
  <div class="container mx-auto px-6 max-w-2xl">
    <div class="text-center mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Apply for Membership</h2>
      <p class="mt-2 text-gray-600">I review every application personally. I'll respond within 24 hours.</p>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
      <div class="bg-gray-900 text-white px-6 py-4">
        <p class="font-semibold">Membership application</p>
        <p class="text-sm text-gray-400 mt-0.5">$1,800/mo · 1 new client per week · Cancel with 2 weeks notice</p>
      </div>
      <form
        name="membership-application"
        method="POST"
        action="/thank-you"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="p-6 space-y-4"
      >
        <input type="hidden" name="form-name" value="membership-application" />
        <input type="hidden" name="service" value="membership-1800" />
        <p class="hidden"><input name="bot-field" /></p>

        <input name="name" required placeholder="Your name"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm" />
        <input name="business" required placeholder="Business name"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm" />
        <input name="email" type="email" required placeholder="Email"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm" />
        <input name="phone" type="tel" required placeholder="Phone"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm" />
        <input name="website" placeholder="Your current website"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm" />
        <select name="monthly_revenue"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm">
          <option value="">Approx. monthly revenue</option>
          <option>Under $10k/mo</option>
          <option>$10k–$30k/mo</option>
          <option>$30k–$80k/mo</option>
          <option>$80k+/mo</option>
        </select>
        <textarea name="goals" rows="3" required placeholder="What does growth look like for your business in the next 6 months?"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm resize-none"></textarea>

        <button type="submit"
          class="w-full px-6 py-3.5 rounded-lg font-semibold text-white bg-emerald-600 hover:bg-emerald-700 transition text-sm">
          Submit Application →
        </button>
        <p class="text-xs text-gray-500 text-center">I'll review your application and respond within 24 hours. No pressure.</p>
      </form>
    </div>
  </div>
</section>

</Layout>

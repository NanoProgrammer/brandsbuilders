---
import Layout from '../../../layouts/Layout.astro';

const seo = {
  title: 'Reactivation Campaign — $1,500 Guaranteed | BrandsBuilders',
  description: 'We reactivate your inactive customer list via SMS and email. $1,500 one-time. Guaranteed $3,000 in sales — or we keep running cycles until we hit it.',
  canonical: 'https://brandsbuilders.ca/apply/reactivation',
};
---

<Layout seo={seo}>

<section class="bg-white py-14">
  <div class="container mx-auto px-6 max-w-5xl grid lg:grid-cols-2 gap-14 items-start">

    <div>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-50 border border-violet-200 text-violet-700 text-sm font-semibold mb-6">
        Reactivation Campaign — $1,500 One-Time
      </div>

      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight">
        Your past customers are your cheapest source of new revenue.
      </h1>

      <p class="mt-5 text-lg text-gray-600 leading-relaxed">
        We reactivate your inactive client list via SMS and email. <strong class="text-gray-800">Guaranteed $3,000 in reactivated sales</strong> — or we run the next cycle at no extra cost until we hit it.
      </p>

      <div class="mt-8 space-y-3">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-700">Campaign launches within 5 days of your onboarding call</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-700">Each cycle runs 3 weeks — full results by day 21</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-700">Up to 4 cycles in the year — each one free if the target wasn't hit</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-700">We improve the data between attempts — smarter with every cycle</span>
        </div>
      </div>

      <div class="mt-8 bg-violet-50 border border-violet-200 rounded-xl p-5">
        <p class="text-sm font-bold text-violet-900 mb-1">The guarantee in plain terms</p>
        <p class="text-sm text-violet-800 leading-relaxed">
          If we don't generate $3,000 in booked sales from your inactive list in the first 3-week cycle, we immediately start the next cycle — improving targeting and messaging — at no extra charge. We do this up to 4 times per year.
        </p>
      </div>
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-xl overflow-hidden">
      <div class="bg-gray-900 text-white px-6 py-4">
        <p class="font-semibold">Start your reactivation campaign</p>
        <p class="text-sm text-gray-400 mt-0.5">Tell us about your business. We respond within 24 hours.</p>
      </div>
      <form
        name="reactivation-inquiry"
        method="POST"
        action="/thank-you"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="p-6 space-y-4"
      >
        <input type="hidden" name="form-name" value="reactivation-inquiry" />
        <input type="hidden" name="service" value="reactivation-1500" />
        <p class="hidden"><input name="bot-field" /></p>

        <input name="name" required placeholder="Your name"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-violet-500 text-sm" />
        <input name="business" required placeholder="Business name"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-violet-500 text-sm" />
        <input name="email" type="email" required placeholder="Email"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-violet-500 text-sm" />
        <input name="phone" type="tel" required placeholder="Phone"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-violet-500 text-sm" />
        <select name="list_size"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-violet-500 text-sm">
          <option value="">Approx. size of your customer list</option>
          <option>Under 100 customers</option>
          <option>100–500 customers</option>
          <option>500–2,000 customers</option>
          <option>2,000+ customers</option>
        </select>
        <select name="industry"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-violet-500 text-sm">
          <option value="">Your industry</option>
          <option>Plumbing</option>
          <option>HVAC</option>
          <option>Dentist / Dental Office</option>
          <option>Roofing</option>
          <option>Electrician</option>
          <option>Pest Control</option>
          <option>Auto Repair</option>
          <option>Chiropractor</option>
          <option>Landscaping</option>
          <option>House Cleaning</option>
          <option>Other</option>
        </select>

        <button type="submit"
          class="w-full px-6 py-3.5 rounded-lg font-semibold text-white bg-violet-700 hover:bg-violet-800 transition text-sm">
          Start Reactivation Campaign →
        </button>
        <p class="text-xs text-gray-500 text-center">$1,500 one-time. Guaranteed $3,000 in sales — or we keep running cycles free.</p>
      </form>
    </div>

  </div>
</section>

<section class="bg-gray-50 py-12 border-y border-gray-200">
  <div class="container mx-auto px-6 max-w-4xl">
    <div class="grid md:grid-cols-3 gap-8 text-center">
      <div>
        <div class="text-2xl font-bold text-gray-900">$1,500</div>
        <div class="text-sm text-gray-500 mt-1">One-time investment</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-violet-700">$3,000</div>
        <div class="text-sm text-gray-500 mt-1">Guaranteed in reactivated sales</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-gray-900">5 days</div>
        <div class="text-sm text-gray-500 mt-1">From call to campaign live</div>
      </div>
    </div>
  </div>
</section>

</Layout>

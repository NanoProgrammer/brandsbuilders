---
import Layout from '../../../layouts/Layout.astro';

const seo = {
  title: 'Get a Website — $900 One-Time | BrandsBuilders',
  description: 'A fast, code-built website for your service business. $900 one-time. Contact form connected to Netlify. Domain ~$20/yr is your only ongoing cost.',
  canonical: 'https://brandsbuilders.ca/apply/web-design',
};
---

<Layout seo={seo}>

<section class="bg-white py-14">
  <div class="container mx-auto px-6 max-w-5xl grid lg:grid-cols-2 gap-14 items-start">

    <div>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-50 border border-blue-200 text-blue-700 text-sm font-semibold mb-6">
        Web Design — $900 One-Time
      </div>

      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight">
        A real website, built in code — not a drag-and-drop template.
      </h1>

      <p class="mt-5 text-lg text-gray-600 leading-relaxed">
        One flat fee. No subscriptions, no monthly page-builder charges. Your only ongoing cost is your domain — roughly <strong class="text-gray-800">$20 per year.</strong>
      </p>

      <div class="mt-8 space-y-3">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-700">Custom-coded — no WordPress, no page builders, no bloat</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-700">Contact form wired to Netlify — leads go straight to your email</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-700">Mobile-first, fast-loading, SEO-ready out of the box</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-700">Live in 1–2 weeks. You own the code. No lock-in.</span>
        </div>
      </div>

      <div class="mt-10 bg-gray-50 border border-gray-200 rounded-xl p-5">
        <p class="text-sm font-semibold text-gray-900 mb-1">Want to see examples first?</p>
        <p class="text-sm text-gray-600 mb-3">We've built 10+ websites for local businesses across Alberta and BC.</p>
        <a href="/proof" class="inline-flex px-5 py-2.5 rounded-lg font-semibold text-gray-700 bg-white border border-gray-300 hover:border-gray-400 transition text-sm">
          View Our Work →
        </a>
      </div>
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-xl overflow-hidden">
      <div class="bg-gray-900 text-white px-6 py-4">
        <p class="font-semibold">Tell us about your project</p>
        <p class="text-sm text-gray-400 mt-0.5">Takes 60 seconds. We respond within 24 hours.</p>
      </div>
      <form
        name="web-design-inquiry"
        method="POST"
        action="/thank-you"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="p-6 space-y-4"
      >
        <input type="hidden" name="form-name" value="web-design-inquiry" />
        <input type="hidden" name="service" value="web-design-900" />
        <p class="hidden"><input name="bot-field" /></p>

        <input name="name" required placeholder="Your name"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
        <input name="business" required placeholder="Business name"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
        <input name="email" type="email" required placeholder="Email"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
        <input name="phone" type="tel" placeholder="Phone (optional)"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
        <input name="current_website" placeholder="Current website (if you have one)"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
        <textarea name="details" rows="3" placeholder="What does your business do? Any specific pages or features you need?"
          class="w-full bg-white border border-gray-300 px-4 py-3 text-gray-900 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm resize-none"></textarea>

        <button type="submit"
          class="w-full px-6 py-3.5 rounded-lg font-semibold text-white bg-gray-900 hover:bg-gray-800 transition text-sm">
          Get Started for $900 →
        </button>
        <p class="text-xs text-gray-500 text-center">One-time fee. No monthly charges. Domain (~$20/yr) is your only ongoing cost.</p>
      </form>
    </div>

  </div>
</section>

<section class="bg-gray-50 py-12 border-y border-gray-200">
  <div class="container mx-auto px-6 max-w-4xl">
    <div class="grid md:grid-cols-3 gap-8 text-center">
      <div>
        <div class="text-2xl font-bold text-gray-900">$900</div>
        <div class="text-sm text-gray-500 mt-1">One-time. That's it.</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-gray-900">~$20/yr</div>
        <div class="text-sm text-gray-500 mt-1">Your only ongoing cost (domain)</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-gray-900">1–2 wks</div>
        <div class="text-sm text-gray-500 mt-1">From kickoff to live</div>
      </div>
    </div>
  </div>
</section>

</Layout>

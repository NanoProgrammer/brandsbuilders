---
import Layout from '../../layouts/Layout.astro';

const seo = {
  title: 'Calgary Business Website — $950 One-Time | BrandsBuilders',
  description: 'Custom website for your Calgary small business. 5–10 pages, Google indexed, booking included. $950 one-time. Done in 2 weeks. 100% satisfaction guarantee.',
  keywords: 'web design Calgary, small business website Calgary, affordable website Calgary',
  canonical: 'https://brandsbuilders.ca/offer',
};
---

<Layout seo={seo}  hideNavigation>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="relative overflow-hidden bg-[#f5f5f7] px-6 pb-20 pt-12 lg:min-h-[94vh] lg:pb-28 lg:pt-16">

  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute left-1/2 top-[-260px] h-[560px] w-[960px] -translate-x-1/2 rounded-full bg-[#ff5a00]/8 blur-[120px]"></div>
    <div class="absolute inset-0 opacity-[0.025]" style="background-image:linear-gradient(to right,#0f172a 1px,transparent 1px),linear-gradient(to bottom,#0f172a 1px,transparent 1px);background-size:72px 72px;"></div>
  </div>

  <div class="relative mx-auto max-w-7xl">

    <!-- TRUST BAR -->
    <div class="mb-8 flex justify-center">
      <div class="inline-flex flex-wrap items-center justify-center gap-2.5 rounded-full border border-[#e5e7eb] bg-white/90 px-5 py-2.5 text-[0.82rem] font-semibold text-[#667085] shadow-sm backdrop-blur">
        <span class="flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-green-500"></span> 10+ Calgary businesses live</span>
        <span class="hidden sm:block text-[#d0d5dd]">·</span>
        <span>No monthly fees</span>
        <span class="hidden sm:block text-[#d0d5dd]">·</span>
        <span>Live in 2 weeks</span>
      </div>
    </div>

    <!-- GRID: copy + form -->
    <div class="grid gap-10 lg:grid-cols-[1.08fr_0.92fr] lg:items-start">

      <!-- LEFT COPY -->
      <div class="max-w-2xl">

        <h1 class="text-[clamp(3.8rem,7.5vw,5.8rem)] font-extrabold leading-[0.88] tracking-[-0.06em] text-[#0f172a]">
          A website that<br/>
          <span class="text-[#ff5a00]">gets you customers.</span>
        </h1>

        <p class="mt-6 max-w-xl text-[1.1rem] leading-[1.85] text-[#667085]">
          Custom-built for your Calgary business. Shows up on Google,
          looks professional, and turns visitors into calls — not just clicks.
        </p>

        <!-- VALUE STACK -->
        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          {[
            'Custom 5–10 page website',
            'Indexed on Google from day one',
            '100% satisfaction guarantee',
          ].map(item => (
            <div class="flex items-center gap-2.5">
              <div class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#fff1e8] text-xs font-bold text-[#ff5a00]">✓</div>
              <span class="text-[0.95rem] text-[#0f172a]">{item}</span>
            </div>
          ))}
        </div>

        <!-- PRICE ANCHOR -->
        <div class="mt-10 flex flex-wrap items-center gap-5">
          <div class="rounded-[24px] bg-[#0f172a] px-7 py-5 text-white shadow-[0_16px_48px_rgba(15,23,42,0.16)]">
            <div class="text-[3.6rem] font-extrabold leading-none tracking-[-0.07em]">$950</div>
            <p class="mt-2 text-xs font-semibold uppercase tracking-[0.1em] text-white/50">One-time · no monthly fees</p>
          </div>
          <div class="space-y-1.5 text-sm text-[#667085]">
            <p><s class="text-[#9ca3af]">$2,000–$15,000</s> at most agencies</p>
            <p><s class="text-[#9ca3af]">$30–$100/mo</s> on page builders</p>
            <p class="font-semibold text-[#0f172a]">One price. No hidden fees. Done.</p>
          </div>
        </div>

        <!-- MOBILE CTA (shown below md, links to form) -->
        <div class="mt-8 lg:hidden">
          <a href="#apply" class="inline-flex h-14 w-full items-center justify-center rounded-2xl bg-[#ff5a00] text-lg font-bold text-white transition hover:bg-[#ff6a1a]">
            Get my website for $950 →
          </a>
          <p class="mt-2 text-center text-sm text-[#667085]">🛡️ Don't love it? Don't pay.</p>
        </div>

        <!-- SOCIAL PROOF -->
        <div class="mt-10 flex items-center gap-4">
          <div class="flex -space-x-2.5">
            <img src="/images/portfolio/refresh-exteriors-thumb.png" alt="" class="h-11 w-11 rounded-full border-[3px] border-[#f5f5f7] object-cover"/>
            <img src="/images/portfolio/bavarian-nuts-thumb.png" alt="" class="h-11 w-11 rounded-full border-[3px] border-[#f5f5f7] object-cover"/>
            <img src="/images/portfolio/vaulted-thumb.png" alt="" class="h-11 w-11 rounded-full border-[3px] border-[#f5f5f7] object-cover"/>
          </div>
          <p class="text-sm text-[#667085]">
            Trusted by Calgary businesses.
            <span class="font-bold text-[#0f172a]">First customer in 7 days.</span>
          </p>
        </div>

      </div>

      <!-- RIGHT FORM -->
      <div id="apply" class="relative overflow-hidden rounded-[32px] border border-[#eceef2] bg-white p-7 shadow-[0_30px_80px_rgba(15,23,42,0.08)] lg:sticky lg:top-24 lg:p-9">

        <div class="absolute right-[-60px] top-[-60px] h-56 w-56 rounded-full bg-[#ff5a00]/8 blur-[80px]"></div>

        <div class="relative">

          <div class="mb-6">
            <div class="inline-flex rounded-full bg-[#fff1e8] px-3.5 py-1.5 text-xs font-bold uppercase tracking-[0.1em] text-[#ff5a00]">Get started</div>
            <h2 class="mt-4 text-3xl font-extrabold leading-[0.95] tracking-[-0.04em] text-[#0f172a]">Get your website.</h2>
            <p class="mt-3 text-[0.95rem] leading-7 text-[#667085]">60 seconds. We'll call within 24 hours.</p>
          </div>

          <form name="website-cpc" method="POST" action="/thank-you" data-netlify="true" netlify-honeypot="bot-field" class="space-y-4" id="offerForm">
            <input type="hidden" name="form-name" value="website-cpc"/>
            <p class="hidden"><input name="bot-field"/></p>

            <div>
              <label class="mb-2 block text-xs font-bold uppercase tracking-[0.08em] text-[#667085]">Name & business</label>
              <input type="text" name="name_business" required placeholder="Jacob — Smith's Plumbing"
                class="h-14 w-full rounded-xl border border-[#e5e7eb] bg-[#fafafa] px-4 text-[1rem] text-[#0f172a] outline-none placeholder:text-[#b0b7c3] focus:border-[#ff5a00] focus:bg-white"/>
            </div>

            <div>
              <label class="mb-2 block text-xs font-bold uppercase tracking-[0.08em] text-[#667085]">Phone</label>
              <input type="tel" name="phone" required placeholder="(403) 555-1234"
                class="h-14 w-full rounded-xl border border-[#e5e7eb] bg-[#fafafa] px-4 text-[1rem] text-[#0f172a] outline-none placeholder:text-[#b0b7c3] focus:border-[#ff5a00] focus:bg-white"/>
            </div>

            <div>
              <label class="mb-2 block text-xs font-bold uppercase tracking-[0.08em] text-[#667085]">Email</label>
              <input type="email" name="email" required placeholder="jacob@smithsplumbing.com"
                class="h-14 w-full rounded-xl border border-[#e5e7eb] bg-[#fafafa] px-4 text-[1rem] text-[#0f172a] outline-none placeholder:text-[#b0b7c3] focus:border-[#ff5a00] focus:bg-white"/>
            </div>

            <button type="submit" id="offerSubmit"
              class="inline-flex h-14 w-full items-center justify-center rounded-xl bg-[#ff5a00] text-[1.05rem] font-bold tracking-[-0.02em] text-white transition hover:bg-[#ff6a1a] hover:shadow-[0_12px_36px_rgba(255,90,0,0.22)]">
              Get my website for $950 →
            </button>

            <p class="text-center text-[0.8rem] text-[#667085]">🛡️ If you don't love it, you don't pay — guaranteed.</p>
          </form>

          <!-- FORM TRUST STRIP -->
          <div class="mt-6 grid grid-cols-3 gap-3 border-t border-[#eceef2] pt-6 text-center">
            <div>
              <p class="text-2xl font-extrabold tracking-tight text-[#0f172a]">$950</p>
              <p class="text-[0.7rem] text-[#667085]">One-time</p>
            </div>
            <div>
              <p class="text-2xl font-extrabold tracking-tight text-[#0f172a]">2 wks</p>
              <p class="text-[0.7rem] text-[#667085]">To go live</p>
            </div>
            <div>
              <p class="text-2xl font-extrabold tracking-tight text-[#0f172a]">100%</p>
              <p class="text-[0.7rem] text-[#667085]">Guarantee</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>


<!-- ═══════════════ ABOUT / CONTEXT ═══════════════ -->
<section class="bg-white px-6 py-20">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-xs font-bold uppercase tracking-[0.15em] text-[#ff5a00]">Who we are</p>
    <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.2rem)] font-extrabold leading-[0.95] tracking-[-0.05em] text-[#0f172a]">
      Built in Calgary,<br/>for Calgary.
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-[1.05rem] leading-[1.9] text-[#667085]">
      BrandsBuilders is a small web studio that builds custom websites for local service businesses. No templates. No bloated agency packages. You work directly with the person building your site — that's how we keep turnaround fast and prices fair.
    </p>
  </div>
</section>


<!-- ═══════════════ PROOF ═══════════════ -->
<section id="proof" class="bg-[#f8fafc] px-6 py-24">
  <div class="mx-auto max-w-7xl">

    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.15em] text-[#ff5a00]">Real results</p>
      <h2 class="mt-4 text-[clamp(2.2rem,5vw,4rem)] font-extrabold leading-[0.95] tracking-[-0.05em] text-[#0f172a]">
        They got customers. Fast.
      </h2>
    </div>

    <!-- STATS + TESTIMONIAL -->
    <div class="mt-16 overflow-hidden rounded-[32px] border border-[#eceef2] bg-white p-6 lg:p-10">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">

        <div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl bg-[#f8fafc] p-6">
              <div class="text-5xl font-extrabold tracking-[-0.06em] text-[#0f172a]">160</div>
              <p class="mt-2 text-[0.95rem] text-[#667085]">website clicks in 3 weeks</p>
            </div>
            <div class="rounded-2xl bg-[#f8fafc] p-6">
              <div class="text-5xl font-extrabold tracking-[-0.06em] text-[#0f172a]">7 days</div>
              <p class="mt-2 text-[0.95rem] text-[#667085]">to first new customer</p>
            </div>
          </div>

          <div class="mt-4 rounded-2xl bg-[#0f172a] p-6 text-white">
            <p class="text-xl font-bold leading-[1.5] tracking-[-0.02em]">
              "The website made us look professional immediately. Customers found us on Google within the first week."
            </p>
            <div class="mt-5 flex items-center gap-3">
              <img src="/images/portfolio/vaulted-thumb.png" alt="Abdul" class="h-11 w-11 rounded-full object-cover"/>
              <div>
                <p class="font-bold text-sm">Abdul</p>
                <p class="text-xs text-white/50">Vaulted YYC · Retro Games, Calgary</p>
              </div>
            </div>
          </div>
        </div>

        <!-- FEATURED PROJECT -->
        <a href="https://refreshedexterior.com" target="_blank" rel="noopener" class="group relative block overflow-hidden rounded-2xl aspect-[4/3]">
          <img src="/images/portfolio/refresh-exteriors.png" alt="Refresh Exteriors website" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/15 to-transparent"></div>
          <div class="absolute bottom-0 p-6">
            <p class="text-sm font-semibold text-white/60">Featured project</p>
            <h3 class="mt-1 text-2xl font-extrabold tracking-tight text-white">Refresh Exteriors</h3>
            <p class="mt-1 text-sm text-white/60">Window Cleaning & Snow Removal · Calgary</p>
            <p class="mt-3 text-sm font-bold text-white">Visit site →</p>
          </div>
        </a>

      </div>
    </div>

    <!-- PORTFOLIO GRID -->
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { name: 'Artilate', stack: 'Handcrafted Chocolate · Calgary', img: '/images/portfolio/artilate.png', url: 'https://artilate.com' },
        { name: 'Brain Freeze Fruit', stack: 'Natural Freezies · Calgary', img: '/images/portfolio/behealthyhappy.png', url: 'https://behealthyhappy.ca' },
        { name: 'Kelly & Sons YYC', stack: 'Local Services · Calgary', img: '/images/portfolio/kellyandsons.png', url: 'https://kellyandsonsyyc.ca' },
        { name: 'Vaulted YYC', stack: 'Retro Games & Pokémon · Calgary', img: '/images/portfolio/vaulted.png', url: null },
        { name: 'Bavarian Nuts YYC', stack: 'Roasted Nuts · Calgary', img: '/images/portfolio/bavarian-nuts.png', url: null },
      ].map(p => (
        <div class="group relative overflow-hidden rounded-2xl border border-[#eceef2] bg-white">
          <div class="aspect-[16/10] overflow-hidden">
            <img src={p.img} alt={p.name} class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy"/>
          </div>
          <div class="p-4">
            <p class="font-bold text-[#0f172a]">{p.name}</p>
            <p class="text-sm text-[#667085]">{p.stack}</p>
            {p.url && <a href={p.url} target="_blank" rel="noopener" class="mt-2 inline-block text-sm font-semibold text-[#ff5a00]">Visit site →</a>}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ═══════════════ MID CTA ═══════════════ -->
<section class="border-y border-[#eceef2] bg-[#fffaf6] px-6 py-8">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4">
    <div>
      <p class="text-lg font-bold text-[#0f172a]">Ready to get found on Google?</p>
      <p class="text-sm text-[#667085]">$950 one-time · 2 weeks · 100% satisfaction guarantee</p>
    </div>
    <a href="#apply" class="inline-flex h-12 items-center justify-center rounded-xl bg-[#ff5a00] px-8 text-[0.95rem] font-bold text-white transition hover:bg-[#ff6a1a]">
      Get my website →
    </a>
  </div>
</section>


<!-- ═══════════════ WHAT'S INCLUDED ═══════════════ -->
<section class="bg-white px-6 py-24">
  <div class="mx-auto max-w-6xl">

    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.15em] text-[#ff5a00]">What you get</p>
      <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.4rem)] font-extrabold leading-[0.95] tracking-[-0.05em] text-[#0f172a]">
        Everything you need.<br/>Nothing you don't.
      </h2>
    </div>

    <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { icon: '🏗️', title: 'Custom 5–10 page website', desc: 'Built by hand — not a template. Home, services, about, contact, and more. Fully responsive.', highlight: true },
        { icon: '🔍', title: 'Indexed on Google', desc: 'Full on-page SEO, sitemap submitted. Google knows you exist from day one.' },
        { icon: '📅', title: 'Booking system', desc: 'Let customers book directly from your site. No more phone tag.' },
        { icon: '💳', title: 'Payment integration', desc: 'Accept deposits or payments online. Close deals before your competitor calls back.' },
        { icon: '📱', title: 'Mobile-first design', desc: '60%+ of local searches happen on phones. Your site looks perfect on every screen.' },
        { icon: '🛡️', title: 'Satisfaction guarantee', desc: "Don't love it? You don't pay. No awkward conversations. No fine print.", green: true },
      ].map(c => (
        <div class:list={[
          'rounded-2xl border p-6 transition',
          c.highlight ? 'border-[#ff5a00]/20 bg-[#fffaf6]' : c.green ? 'border-emerald-200 bg-emerald-50/50' : 'border-[#eceef2] bg-white'
        ]}>
          <div class="text-2xl">{c.icon}</div>
          <h3 class="mt-3 text-[1rem] font-bold text-[#0f172a]">{c.title}</h3>
          <p class="mt-2 text-[0.9rem] leading-relaxed text-[#667085]">{c.desc}</p>
        </div>
      ))}
    </div>

    <!-- PRICE COMPARISON -->
    <div class="mx-auto mt-14 flex max-w-2xl flex-wrap items-center justify-between gap-6 rounded-2xl border border-[#eceef2] bg-[#f8fafc] p-6">
      <div class="flex items-baseline gap-3">
        <span class="text-5xl font-extrabold tracking-[-0.06em] text-[#0f172a]">$950</span>
        <span class="text-sm font-semibold text-[#ff5a00]">one-time · forever</span>
      </div>
      <div class="text-sm text-[#667085] space-y-1">
        <p>vs. <s>$2,000–$15,000</s> at most agencies</p>
        <p>vs. <s>$30–$100/mo</s> with page builders</p>
      </div>
    </div>

  </div>
</section>


<!-- ═══════════════ OBJECTIONS ═══════════════ -->
<section class="bg-[#f8fafc] px-6 py-24">
  <div class="mx-auto max-w-4xl">

    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.15em] text-[#ff5a00]">Common questions</p>
      <h2 class="mt-4 text-[clamp(2rem,4.5vw,3rem)] font-extrabold leading-[0.95] tracking-[-0.05em] text-[#0f172a]">
        You're probably wondering…
      </h2>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      {[
        { q: 'Why is this cheaper than other agencies?', a: "No offices, no project managers, no bloated teams. You talk directly to the person building your site. We focus only on Calgary businesses, so we're fast and efficient." },
        { q: 'What if I don\'t like the design?', a: "You don't pay. That's the guarantee. We work through revisions until you love it — and if we can't, you walk away owing nothing." },
        { q: 'Do I pay anything monthly after?', a: "Nothing to us. Hosting is included. The only cost is your domain (~$15/year), which you own outright. No lock-in." },
        { q: 'What do you need from me?', a: "A 15-minute call, your logo if you have one, and photos. We handle all copy, design, development, and launch." },
      ].map(faq => (
        <div class="rounded-2xl border border-[#eceef2] bg-white p-6">
          <h3 class="text-[0.95rem] font-bold text-[#0f172a]">{faq.q}</h3>
          <p class="mt-3 text-[0.9rem] leading-relaxed text-[#667085]">{faq.a}</p>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ═══════════════ QUALIFICATION ═══════════════ -->
<section class="bg-white px-6 py-24">
  <div class="mx-auto max-w-4xl">

    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.15em] text-[#ff5a00]">Is this for you?</p>
      <h2 class="mt-4 text-[clamp(2rem,4.5vw,3rem)] font-extrabold leading-[0.95] tracking-[-0.05em] text-[#0f172a]">
        We work with real Calgary businesses.
      </h2>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">

      <!-- YES -->
      <div class="rounded-2xl border border-emerald-200 bg-emerald-50/40 p-6">
        <h3 class="text-[0.95rem] font-bold text-[#0f172a]">✅ This is for you if…</h3>
        <ul class="mt-4 space-y-2.5 text-[0.9rem] text-[#667085]">
          <li>You run a service business in Calgary or Alberta</li>
          <li>You have customers but no website — or an embarrassing one</li>
          <li>You charge a real price per job (not $10–$20 items)</li>
          <li>You want customers to find you on Google</li>
          <li>You're ready to move in the next 2 weeks</li>
        </ul>
      </div>

      <!-- NO -->
      <div class="rounded-2xl border border-red-200 bg-red-50/40 p-6">
        <h3 class="text-[0.95rem] font-bold text-[#0f172a]">❌ Not for you if…</h3>
        <ul class="mt-4 space-y-2.5 text-[0.9rem] text-[#667085]">
          <li>You're still in the idea stage with no customers</li>
          <li>You need an e-commerce store with 20+ products</li>
          <li>You want to build it yourself</li>
          <li>You're not available for a quick discovery call</li>
        </ul>
      </div>

    </div>

    <!-- INDUSTRY TAGS -->
    <div class="mt-10 text-center">
      <p class="text-sm font-semibold text-[#667085]">Perfect for businesses like:</p>
      <div class="mt-4 flex flex-wrap justify-center gap-2">
        {['Plumbers','Electricians','Contractors','Landscapers','Cleaners','Dentists','Chiropractors','Personal Trainers','Photographers','Accountants','Lawyers','Mechanics'].map(t => (
          <span class="rounded-full border border-[#eceef2] bg-[#f8fafc] px-4 py-1.5 text-sm text-[#667085]">{t}</span>
        ))}
      </div>
    </div>

  </div>
</section>


<!-- ═══════════════ PROCESS ═══════════════ -->
<section class="bg-[#f8fafc] px-6 py-24">
  <div class="mx-auto max-w-3xl">

    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.15em] text-[#ff5a00]">How it works</p>
      <h2 class="mt-4 text-[clamp(2rem,4.5vw,3rem)] font-extrabold leading-[0.95] tracking-[-0.05em] text-[#0f172a]">
        Apply today. Live in 2 weeks.
      </h2>
    </div>

    <div class="mt-12 space-y-3">
      {[
        { n: '1', title: 'Fill out the form above', desc: '60 seconds. We review every application within 24 hours.' },
        { n: '2', title: '15-minute discovery call', desc: 'Tell us about your business. We handle everything from here.' },
        { n: '3', title: 'We build your site', desc: 'Custom design + development. You review, we refine.' },
        { n: '4', title: 'You go live', desc: 'Show up on Google. Get found. Get more jobs.' },
      ].map(s => (
        <div class="flex gap-5 rounded-2xl border border-[#eceef2] bg-white p-5">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#fff1e8] text-lg font-extrabold text-[#ff5a00]">{s.n}</div>
          <div>
            <h3 class="text-[0.95rem] font-bold text-[#0f172a]">{s.title}</h3>
            <p class="mt-1 text-[0.9rem] text-[#667085]">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ═══════════════ FINAL CTA ═══════════════ -->
<section class="bg-[#0f172a] px-6 py-24 text-center text-white">
  <div class="mx-auto max-w-2xl">

    <h2 class="text-[clamp(2.2rem,5vw,3.8rem)] font-extrabold leading-[0.95] tracking-[-0.05em]">
      Stop losing customers to competitors with better websites.
    </h2>

    <p class="mx-auto mt-6 max-w-xl text-lg text-white/60">
      $950 one-time. Live in 2 weeks. If you don't love it, you don't pay.
    </p>

    <a href="#apply"
      class="mt-8 inline-flex h-14 items-center justify-center rounded-2xl bg-[#ff5a00] px-10 text-lg font-bold text-white transition hover:bg-[#ff6a1a] hover:shadow-[0_12px_40px_rgba(255,90,0,0.3)]">
      Get my website for $950 →
    </a>

    <p class="mt-4 text-sm text-white/40">🛡️ 100% satisfaction guarantee. No spam. We'll call within 24 hours.</p>

  </div>
</section>

</Layout>

<script>
  // Form submit handler
  const form = document.getElementById('offerForm') as HTMLFormElement | null;
  const btn = document.getElementById('offerSubmit') as HTMLButtonElement | null;
  form?.addEventListener('submit', () => {
    (window as any).fbq?.('track', 'Lead');
    if (btn) {
      btn.textContent = "✓ Sent — we'll call within 24 hours";
      btn.style.background = '#16a34a';
      btn.disabled = true;
    }
  });

  // Sticky bar
  const bar = document.getElementById('stickyBar');
  if (bar) {
    window.addEventListener('scroll', () => {
      bar.classList.toggle('show', window.scrollY > 500);
    }, { passive: true });
  }
</script>
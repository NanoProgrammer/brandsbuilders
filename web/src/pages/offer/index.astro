---
import Layout from '../../layouts/Layout.astro';

const seo = {
  title: 'Calgary Business Website — Under $1,000 | BrandsBuilders',
  description: 'Custom website for your Calgary small business. 5–10 pages, Google indexed, booking or payments included. One-time $950. Done in 2 weeks. 100% satisfaction guarantee.',
  keywords: 'web design Calgary, small business website Calgary, affordable website Calgary, Calgary web designer',
  canonical: 'https://brandsbuilders.ca/offer',
};
---

<Layout seo={seo}>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,700;12..96,800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet" />

<!-- STICKY BAR -->
<div class="sticky" id="stickyBar">
  <p><strong>$950 one-time.</strong> No monthly fees. Calgary business website in 2 weeks.</p>
  <a href="#apply">Get mine →</a>
</div>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hb-blob hb-1"></div>
    <div class="hb-blob hb-2"></div>
    <div class="hb-grid"></div>
  </div>

  <div class="hero-body">
   

    <h1>
      Your Calgary business<br/>
      deserves a website that<br/>
      <em>actually gets you clients.</em>
    </h1>

    <p class="hero-p">
      Custom 5–10 page website. Google indexed. Booking or payments included.<br/>
      <strong>$950 one-time — no monthly fees. Live in 2 weeks.</strong>
    </p>

    <a href="#apply" class="cta-btn hero-cta">Get my website for $950 →</a>
    <p class="hero-micro">🛡️ If you don't love it, you don't pay — guaranteed.</p>

    <div class="hero-social">
      <div class="hs-avatars">
        <img src="/images/portfolio/refresh-exteriors-thumb.png" alt="Refresh Exteriors" width="28" height="28"/>
        <img src="/images/portfolio/bavarian-nuts-thumb.png" alt="Bavarian Nuts YYC" width="28" height="28"/>
        <img src="/images/portfolio/vaulted-thumb.png" alt="Vaulted YYC" width="28" height="28"/>
      </div>
      <p><strong>3 Calgary businesses</strong> live — first client in as little as <strong>7 days</strong></p>
    </div>
  </div>

  <div class="hero-stats">
    <div class="hs"><b>$950</b><span>One-time. No monthly fees.</span></div>
    <div class="hs-div"></div>
    <div class="hs"><b>2 weeks</b><span>Call to live site.</span></div>
    <div class="hs-div"></div>
    <div class="hs"><b>5–10 pages</b><span>Custom. Not a template.</span></div>
    <div class="hs-div"></div>
    <div class="hs"><b>100%</b><span>Satisfaction guarantee.</span></div>
  </div>
</section>

<!-- ═══════════════ PROOF ═══════════════ -->
<section class="sec alt" id="proof">
  <div class="wrap">
    <p class="eyebrow">Real results</p>
    <h2>They got clients.<br/><em>Fast.</em></h2>

    <div class="testimonial">
      <div class="t-nums">
        <div class="t-num"><b>160</b><span>website clicks in 3 weeks</span></div>
        <div class="t-rule"></div>
        <div class="t-num"><b>7 days</b><span>to first new customer</span></div>
      </div>
      <div class="t-who">
        <img src="/images/portfolio/vaulted-thumb.png" alt="Abdul" width="44" height="44"/>
        <div>
          <strong>Abdul</strong>
          <span>Vaulted YYC · Retro Games &amp; Pokémon, Calgary</span>
        </div>
      </div>
    </div>

    <div class="port-grid">
      <div class="port-card port-feat">
        <img src="/images/portfolio/refresh-exteriors.png" alt="Refresh Exteriors website" loading="lazy"/>
        <div class="port-ov">
          <strong>Refresh Exteriors</strong>
          <span>Window Cleaning &amp; Snow Removal · Calgary, AB</span>
          <a href="https://refreshedexterior.com" target="_blank" rel="noopener">Visit site →</a>
        </div>
      </div>
      <div class="port-card">
        <img src="/images/portfolio/vaulted.png" alt="Vaulted YYC website" loading="lazy"/>
        <div class="port-ov"><strong>Vaulted YYC</strong><span>Retro Games &amp; Pokémon · Calgary</span></div>
      </div>
      <div class="port-card">
        <img src="/images/portfolio/bavarian-nuts.png" alt="Bavarian Nuts YYC website" loading="lazy"/>
        <div class="port-ov"><strong>Bavarian Nuts YYC</strong><span>Roasted Nuts &amp; Snacks · Calgary</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ MID CTA ═══════════════ -->
<div class="mid-cta">
  <div class="wrap mid-cta-inner">
    <div>
      <p class="mid-cta-h">Ready to get found on Google?</p>
      <p class="mid-cta-s">$950 one-time &nbsp;·&nbsp; 2 weeks &nbsp;·&nbsp; 100% satisfaction guarantee</p>
    </div>
    <a href="#apply" class="cta-btn">Get my website →</a>
  </div>
</div>

<!-- ═══════════════ OFFER ═══════════════ -->
<section class="sec">
  <div class="wrap">
    <p class="eyebrow">What's included</p>
    <h2>Everything you need.<br/><em>Nothing you don't.</em></h2>

    <div class="offer-grid">
      <div class="card card-accent">
        <div class="card-badge">Included</div>
        <div class="card-icon">🏗️</div>
        <h3>Custom 5–10 page website</h3>
        <p>Built by hand — not a template. Home, services, about, contact, and more. Fully responsive on every device.</p>
      </div>
      <div class="card">
        <div class="card-icon">🔍</div>
        <h3>Indexed on Google</h3>
        <p>Full on-page SEO, sitemap submitted. Google knows you exist from day one.</p>
      </div>
      <div class="card">
        <div class="card-icon">📅</div>
        <h3>Booking system</h3>
        <p>Let customers book directly from your site. No more phone tag to schedule a job.</p>
      </div>
      <div class="card">
        <div class="card-icon">💳</div>
        <h3>Payment integration</h3>
        <p>Accept deposits or payments online. Close deals before your competitor calls back.</p>
      </div>
      <div class="card">
        <div class="card-icon">📱</div>
        <h3>Mobile-first design</h3>
        <p>60%+ of local searches happen on phones. Your site looks perfect on every screen.</p>
      </div>
      <div class="card card-green">
        <div class="card-icon">🛡️</div>
        <h3>100% satisfaction guarantee</h3>
        <p>Don't love it? <strong>You don't pay.</strong> No awkward conversations. No fine print. We've never had to use this.</p>
      </div>
    </div>

    <div class="price-block">
      <div class="price-l">
        <span class="price-n">$950</span>
        <span class="price-tag">one-time · no monthly fees · ever</span>
      </div>
      <div class="price-r">
        <p>vs. $2,000–$15,000 at most agencies</p>
        <p>vs. $30–$100/month on page builders</p>
        <p class="price-ref">🤝 Refer a client → you pay only <strong>$700</strong></p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ OBJECTIONS ═══════════════ -->
<section class="sec alt">
  <div class="wrap">
    <p class="eyebrow">Common questions</p>
    <h2>You're probably<br/><em>wondering...</em></h2>

    <div class="obj-grid">
      <div class="obj-card">
        <h4>Why is this cheaper than other agencies?</h4>
        <p>We work lean — no offices, no project managers, no bloated teams. You talk directly to the person building your site. We focus only on local Calgary businesses, so we're fast and efficient at exactly this.</p>
      </div>
      <div class="obj-card">
        <h4>What if I don't like the design?</h4>
        <p>You don't pay. That's the guarantee. We work through revisions until you love it — and if we still can't make you happy, you walk away owing nothing.</p>
      </div>
      <div class="obj-card">
        <h4>Do I pay anything monthly after?</h4>
        <p>No. Domain (~$15/year) and hosting is on our end. Everything are yours to control directly. We don't lock you into anything.</p>
      </div>
      <div class="obj-card">
        <h4>What do you need from me?</h4>
        <p>A 15-minute call, your logo if you have one, and photos if you want them. We handle all copy, design, development, and launch.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ QUALIFY ═══════════════ -->
<section class="sec">
  <div class="wrap">
    <p class="eyebrow">Is this for you?</p>
    <h2>We work with<br/><em>real Calgary businesses.</em></h2>

    <div class="q-grid">
      <div class="q-col q-yes">
        <h3>✅ &nbsp;This is for you if...</h3>
        <ul>
          <li>You run a service-based business in Calgary or Alberta</li>
          <li>You have customers but no website — or an embarrassing one</li>
          <li>You charge a real price per job (not $10–$20 items)</li>
          <li>You want customers to find you on Google</li>
          <li>You're ready to move in the next 2 weeks</li>
        </ul>
      </div>
      <div class="q-col q-no">
        <h3>❌ &nbsp;This is NOT for you if...</h3>
        <ul>
          <li>You're still in the idea stage with no customers yet</li>
          <li>You need an ecommerce store with 20+ products</li>
          <li>You want to build it yourself</li>
          <li>You're not available for a quick discovery call</li>
        </ul>
      </div>
    </div>

    <div class="ideal">
      <p class="ideal-label">Perfect for businesses like:</p>
      <div class="tags">
        <span>Plumbers</span><span>Electricians</span><span>Contractors</span>
        <span>Landscapers</span><span>Cleaning services</span><span>Dentists</span>
        <span>Chiropractors</span><span>Personal trainers</span><span>Photographers</span>
        <span>Accountants</span><span>Lawyers</span><span>Mechanics</span>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ PROCESS ═══════════════ -->
<section class="sec alt">
  <div class="wrap">
    <p class="eyebrow">How it works</p>
    <h2>Apply today.<br/><em>Live in 2 weeks.</em></h2>

    <ol class="steps">
      <li class="step">
        <span class="step-n">01</span>
        <div>
          <h4>Fill out the form below</h4>
          <p>60 seconds. We review every application within 24 hours.</p>
        </div>
      </li>
      <li class="step">
        <span class="step-n">02</span>
        <div>
          <h4>15-minute discovery call</h4>
          <p>Tell us about your business. We handle everything else from here.</p>
        </div>
      </li>
      <li class="step">
        <span class="step-n">03</span>
        <div>
          <h4>We build your site</h4>
          <p>Custom design + development. You review, request changes, we refine.</p>
        </div>
      </li>
      <li class="step">
        <span class="step-n">04</span>
        <div>
          <h4>You go live</h4>
          <p>Show up on Google. Get found by customers. Get more jobs.</p>
        </div>
      </li>
    </ol>
  </div>
</section>

<!-- ═══════════════ FORM ═══════════════ -->
<section class="sec form-sec" id="apply">
  <div class="wrap">
    <p class="eyebrow">Get started</p>
    <h2>Let's build your<br/><em>Calgary business website.</em></h2>
    <p class="form-sub">Takes 60 seconds. We'll reach out within 24 hours to book your discovery call.</p>

    <div class="form-wrap">
      <form name="website-cpc" method="POST" data-netlify="true" netlify-honeypot="bot-field" id="appForm">
        <input type="hidden" name="form-name" value="website-cpc"/>
        <p style="display:none"><label>Don't fill this: <input name="bot-field"/></label></p>

        <div class="field">
          <label for="f-name">Your name &amp; business</label>
          <input id="f-name" type="text" name="name_business" required placeholder="Jacob — Smith's Plumbing"/>
        </div>
        <div class="field">
          <label for="f-phone">Phone number</label>
          <input id="f-phone" type="tel" name="phone" required placeholder="(403) 555-1234"/>
        </div>
        <div class="field">
          <label for="f-email">Email address</label>
          <input id="f-email" type="email" name="email" required placeholder="jacob@smithsplumbing.com"/>
        </div>

        <button type="submit" class="cta-btn submit-btn" id="submitBtn">
          Get my website for $950 →
        </button>
        <p class="form-micro">🛡️ 100% satisfaction guarantee — don't love it, you don't pay. No spam. We'll call within 24 hours.</p>
      </form>

      <aside class="form-side">
        <ul class="fs-list">
          <li><span>✅</span> Custom 5–10 page website</li>
          <li><span>✅</span> Indexed on Google from day one</li>
          <li><span>✅</span> Booking or payments included</li>
          <li><span>✅</span> Live in 2 weeks</li>
          <li><span>✅</span> One-time $950 — no monthly fees</li>
          <li><span>🛡️</span> 100% satisfaction guarantee</li>
        </ul>
        <div class="fs-price">
          <b>$950</b>
          <span>one-time · no monthly fees · ever</span>
        </div>
        <div class="fs-ref">
          🤝 if you bring a client → you pay only <strong>$700</strong>
        </div>
      </aside>
    </div>
  </div>
</section>

</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,700;12..96,800&family=DM+Sans:opsz,wght@9..40,400;9..40,500&display=swap');

  /* ── TOKENS ── */
  :root {
    --bg:    #06040f;
    --bg2:   #09071a;
    --card:  #0e0c1e;
    --b1:    #1a1730;
    --b2:    #231f3a;
    --ink:   #eae6ff;
    --muted: #8880a8;
    --dim:   #57527a;
    --fire:  #ff3e6c;
    --amber: #ff8c00;
    --teal:  #00e5a0;
    --grad:  linear-gradient(135deg,#ff3e6c,#ff8c00);
    --f-head:'Bricolage Grotesque',sans-serif;
    --f-body:'DM Sans',sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { overflow-x: hidden; scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--ink); font-family: var(--f-body); font-size: 16px; line-height: 1.6; }

  img { display: block; max-width: 100%; }
  strong { font-weight: 700; }
  a { color: inherit; }

  /* ── STICKY ── */
  .sticky {
    position: fixed; top: 0; inset-inline: 0; z-index: 900;
    display: flex; align-items: center; justify-content: center; gap: 2rem;
    padding: .6rem 1.5rem;
    background: rgba(6,4,15,.92); backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--b2);
    font-size: .82rem; color: var(--muted);
    transform: translateY(-110%); transition: transform .3s ease;
  }
  .sticky.show { transform: translateY(0); }
  .sticky strong { color: var(--ink); }
  .sticky a {
    flex-shrink: 0;
    background: var(--grad); color: #fff;
    font-family: var(--f-head); font-weight: 700; font-size: .8rem;
    padding: .38rem 1rem; border-radius: 8px; text-decoration: none;
    transition: opacity .15s;
  }
  .sticky a:hover { opacity: .85; }
  @media(max-width:560px){ .sticky p { display: none; } }

  /* ── HERO ── */
  .hero { position: relative; overflow: hidden; margin-top: -6rem; }

  .hero-bg { position: absolute; inset: 0; pointer-events: none; }
  .hb-blob {
    position: absolute; border-radius: 50%; filter: blur(120px); opacity: .28;
  }
  .hb-1 {
    width: 560px; height: 560px;
    background: radial-gradient(circle,rgba(255,62,108,.55),transparent 70%);
    top: -180px; left: -140px;
  }
  .hb-2 {
    width: 480px; height: 480px;
    background: radial-gradient(circle,rgba(100,60,255,.45),transparent 70%);
    top: -60px; right: -120px;
  }
  .hb-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black, transparent);
  }

  .hero-body {
    position: relative; z-index: 2;
    max-width: 800px; margin: 0 auto;
    padding: 7rem 1.5rem 4rem;
    text-align: center;
  }

  /* tag pill */
  .tag {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: .72rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
    color: rgba(255,255,255,.38);
    border: 1px solid rgba(255,255,255,.1); border-radius: 100px;
    padding: .38rem 1rem; margin-bottom: 2.25rem;
  }
  
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.25} }

  /* headlines */
  h1 {
    font-family: var(--f-head);
    font-weight: 800;
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    line-height: .97;
    letter-spacing: -.045em;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  h2 {
    font-family: var(--f-head);
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -.04em;
    color: var(--ink);
    margin-bottom: 2.5rem;
    text-align: center;
  }
  h1 em, h2 em {
    font-style: normal;
    background: var(--grad);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }

  .hero-p {
    font-size: 1.05rem; line-height: 1.7;
    color: var(--muted); max-width: 560px; margin: 0 auto 2.25rem;
  }
  .hero-p strong { color: var(--ink); }

  /* CTA button */
  .cta-btn {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--grad); color: #fff;
    font-family: var(--f-head); font-weight: 700; font-size: 1rem;
    padding: .9rem 2.2rem; border-radius: 10px;
    border: none; cursor: pointer; text-decoration: none;
    box-shadow: 0 0 40px rgba(255,62,108,.25);
    transition: transform .18s, box-shadow .18s;
  }
  .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 0 60px rgba(255,62,108,.35); }
  .hero-cta { font-size: 1.1rem; padding: 1rem 2.6rem; }

  .hero-micro { font-size: .8rem; color: var(--dim); margin-top: .75rem; }

  .hero-social {
    display: inline-flex; align-items: center; gap: .75rem;
    background: rgba(0,229,160,.05); border: 1px solid rgba(0,229,160,.14);
    border-radius: 100px; padding: .45rem 1rem .45rem .55rem;
    margin-top: 2rem;
  }
  .hs-avatars { display: flex; }
  .hs-avatars img {
    width: 28px; height: 28px; border-radius: 50%;
    object-fit: cover; border: 2px solid var(--bg); margin-right: -7px;
  }
  .hs-avatars img:last-child { margin-right: 0; }
  .hero-social p { font-size: .8rem; color: var(--muted); }
  .hero-social strong { color: var(--ink); }

  /* stats bar */
  .hero-stats {
    position: relative; z-index: 2;
    display: flex; justify-content: center; align-items: center;
    flex-wrap: wrap; gap: 2rem;
    padding: 1.75rem 2rem;
    border-top: 1px solid var(--b1); border-bottom: 1px solid var(--b1);
    background: rgba(9,7,26,.65); backdrop-filter: blur(12px);
  }
  .hs { text-align: center; }
  .hs b {
    display: block;
    font-family: var(--f-head); font-weight: 800; font-size: 1.6rem; letter-spacing: -.04em;
    background: var(--grad); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .hs span { display: block; font-size: .75rem; color: var(--dim); margin-top: .1rem; }
  .hs-div { width: 1px; height: 32px; background: var(--b2); }

  /* ── LAYOUT ── */
  .sec { padding: 5.5rem 1.5rem; }
  .alt { background: var(--bg2); }
  .wrap { max-width: 1060px; margin: 0 auto; }

  .eyebrow {
    display: block; text-align: center;
    font-size: .68rem; font-weight: 700; letter-spacing: .16em; text-transform: uppercase;
    color: var(--dim); margin-bottom: .55rem;
  }

  /* ── PROOF ── */
  .testimonial {
    max-width: 640px; margin: 0 auto 3rem;
    background: var(--card); border: 1px solid var(--b2);
    border-radius: 18px; padding: 2rem;
  }
  .t-nums {
    display: flex; align-items: center; justify-content: center; gap: 2.5rem;
    padding-bottom: 1.5rem; margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--b1);
  }
  .t-num { text-align: center; }
  .t-num b {
    display: block;
    font-family: var(--f-head); font-weight: 800; font-size: 2.2rem; letter-spacing: -.04em;
    background: var(--grad); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .t-num span { font-size: .78rem; color: var(--muted); margin-top: .15rem; display: block; }
  .t-rule { width: 1px; height: 36px; background: var(--b2); }
  .t-who { display: flex; align-items: center; gap: .85rem; }
  .t-who img { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; border: 2px solid var(--b2); }
  .t-who strong { display: block; font-family: var(--f-head); font-weight: 700; font-size: .95rem; }
  .t-who span { font-size: .78rem; color: var(--muted); }

  .port-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media(max-width:600px){ .port-grid { grid-template-columns: 1fr; } }
  .port-feat { grid-column: 1/-1; }

  .port-card {
    position: relative; border-radius: 14px; overflow: hidden;
    border: 1px solid var(--b1); aspect-ratio: 16/9;
    transition: border-color .2s, transform .2s;
  }
  .port-feat { aspect-ratio: 16/6; }
  .port-card:hover { border-color: rgba(255,62,108,.35); transform: translateY(-2px); }
  .port-card img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
  .port-ov {
    position: absolute; bottom: 0; inset-inline: 0; padding: 1rem 1.25rem;
    background: linear-gradient(transparent, rgba(6,4,15,.96));
  }
  .port-ov strong { display: block; font-family: var(--f-head); font-size: .95rem; }
  .port-ov span { display: block; font-size: .75rem; color: var(--muted); }

<script>
  // Sticky bar
  const bar = document.getElementById('stickyBar');
  window.addEventListener('scroll', () => {
    bar?.classList.toggle('show', window.scrollY > 480);
  }, { passive: true });

  // Form
  const form = document.getElementById('appForm') as HTMLFormElement | null;
  const btn  = document.getElementById('submitBtn') as HTMLButtonElement | null;
  form?.addEventListener('submit', (e) => {
    let ok = true;
    form.querySelectorAll<HTMLInputElement>('input[required]').forEach(inp => {
      const empty = !inp.value.trim();
      inp.style.borderColor = empty ? '#ff3e6c' : '';
      if (empty) ok = false;
    });
    if (!ok) { e.preventDefault(); return; }
    (window as any).fbq?.('track', 'Lead');
    if (btn) {
      btn.textContent = "✓ Sent — we'll call within 24 hours";
      btn.style.background = '#00e5a0';
      btn.disabled = true;
    }
  });

  // Fade in on scroll
  const io = new IntersectionObserver(entries => {
    entries.forEach(({ target, isIntersecting }) => {
      if (!isIntersecting) return;
      (target as HTMLElement).style.cssText += 'opacity:1;transform:translateY(0)';
      io.unobserve(target);
    });
  }, { threshold: .08 });

  document.querySelectorAll('.card,.obj-card,.q-col,.step,.port-card,.testimonial').forEach(el => {
    (el as HTMLElement).style.cssText += 'opacity:0;transform:translateY(18px);transition:opacity .5s ease,transform .5s ease';
    io.observe(el);
  });
</script>
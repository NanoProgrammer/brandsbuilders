---
import Layout from '../../layouts/Layout.astro';
const seo = { title: 'Privacy Policy — BrandsBuilders', description: 'How BrandsBuilders collects, uses, and protects personal information.', canonical: 'https://brandsbuilders.ca/privacy-policy' };
---
<Layout seo={seo}>
<section class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-3xl">
    <p class="text-sm text-gray-500 uppercase tracking-wider mb-4">Legal</p>
    <h1 class="text-4xl font-bold text-gray-900 mb-2">Privacy Policy</h1>
    <p class="text-sm text-gray-500 mb-12">Last updated: 2026-06-18</p>
    <div class="prose prose-gray max-w-none text-gray-600 leading-relaxed space-y-6">
      <p>BrandsBuilders collects only the minimum personal information required to evaluate fit, deliver services, and communicate responsibly.</p>
      <h2 class="text-xl font-semibold text-gray-900 mt-8">Information We Collect</h2>
      <p>Application/intake forms (name, email, business details), messages sent through our website, and basic technical data (IP, browser) for site performance.</p>
      <h2 class="text-xl font-semibold text-gray-900 mt-8">How We Use Information</h2>
      <p>To review applications, communicate regarding inquiries, deliver services, and meet legal obligations.</p>
      <h2 class="text-xl font-semibold text-gray-900 mt-8">Canadian Law</h2>
      <p>We comply with PIPEDA and CASL. We do not sell personal information. You may unsubscribe at any time.</p>
      <h2 class="text-xl font-semibold text-gray-900 mt-8">Contact</h2>
      <p>BrandsBuilders · Alberta, Canada · <a href="mailto:hello@brandsbuilders.ca" class="text-orange-600">hello@brandsbuilders.ca</a></p>
    </div>
  </div>
</section>
</Layout>

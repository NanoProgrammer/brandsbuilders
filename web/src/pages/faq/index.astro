---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: 'How does missed-call recovery work?', a: 'When a call goes unanswered, the system automatically sends an SMS within 60 seconds to keep the conversation going and guide the lead toward booking — 24/7, with no extra effort from you. Free for 30 days, then $25 per booking recovered.' },
  { q: 'What is included in the $900 website?', a: 'A custom, high-conversion website built for your home service business. One-time $900 fee, no monthly subscriptions. Live in 1–2 weeks. Includes hosting setup, contact forms, and tracking.' },
  { q: 'What does the $1,500 reactivation campaign do?', a: 'We reach back out to your past customers via SMS and email to book new jobs. Guaranteed $3,000 in reactivated revenue or we run the next campaign free.' },
  { q: 'What is the $1,800/month membership?', a: 'Our full-service growth system: missed-call recovery, website CRO, Google/Meta Ads management, reactivation campaigns, and monthly reporting. Designed to bring in at least 1 new client per week.' },
  { q: 'Is ad spend included in the membership?', a: 'No. Ad spend is billed directly from your own Google or Meta Ads account so you keep full ownership. We recommend starting at $500–$1,500/month depending on your market.' },
  { q: 'How fast can I go live with ads?', a: '2–3 weeks from kickoff to a live website. Ads launch shortly after, once tracking is confirmed working correctly.' },
  { q: 'Is there a contract?', a: 'No long-term contracts. Missed-call recovery is month-to-month. The membership requires 2 weeks notice to cancel.' },
  { q: 'What reporting do I get?', a: 'Every month: leads generated, cost per lead, lead source, and conversions — in plain numbers, not vague summaries.' },
  { q: 'Who is this for?', a: 'Home service businesses in Western Canada — plumbers, HVAC techs, roofers, electricians, landscapers, cleaners, and similar trades — who want more booked jobs without wasting money on marketing that doesn\'t convert.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const seo = {
  title: 'FAQ — Missed-Call Recovery, Web Design & Growth Services | BrandsBuilders',
  description: 'Answers to the most common questions about BrandsBuilders services: $900 websites, missed-call recovery, $1,500 reactivation campaigns, and the $1,800/mo growth membership.',
  canonical: 'https://brandsbuilders.ca/faq',
  schema: faqSchema,
};
---
<Layout seo={seo}>
<section class="bg-white py-16">
  <div class="container mx-auto px-6 max-w-3xl">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Frequently asked questions</h1>
    <p class="text-lg text-gray-600 mb-12">About missed-call recovery, websites, reactivation campaigns, and the growth membership.</p>
    <div class="space-y-4">
      {faqs.map((f) => (
        <details class="bg-gray-50 border border-gray-200 rounded-xl p-5 group">
          <summary class="cursor-pointer font-medium text-gray-900 flex justify-between items-center">
            {f.q}
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>
    <div class="mt-12 bg-gray-900 text-white rounded-xl p-8 text-center">
      <h2 class="text-2xl font-bold mb-3">Still have questions?</h2>
      <a href="/apply" class="inline-block mt-2 px-8 py-3 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">Get Started →</a>
    </div>
  </div>
</section>
</Layout>

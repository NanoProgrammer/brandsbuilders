---
import Layout from '../../layouts/Layout.astro';
const seo = {
  title: 'FAQ — Tier 1 System | BrandsBuilders',
  description: 'Common questions about the $1,500/mo website, ads, and lead recovery system.',
  canonical: 'https://brandsbuilders.ca/faq'
};
const faqs = [
  { q: 'What\'s included for $1,500/month?', a: 'A high-conversion website build (or rebuild), Google or Meta Ads management on one platform, basic creative testing (2–3 ad variations per month), a dedicated tracked phone number, missed-call SMS protection, and monthly reporting. One flat fee, no upsells.' },
  { q: 'Is ad spend included in the $1,500?', a: 'No. Ad spend is billed directly from your own Google Ads or Meta Ads account, so you keep full ownership and control of it. We recommend starting at $500–$1,500/month depending on your market and goals.' },
  { q: 'Do I get both Google Ads and Meta Ads?', a: 'The service includes one platform. We help you decide which one fits your business and audience best before we start.' },
  { q: 'Who creates the ad creatives?', a: 'We script and edit. For video/photo creatives, you record the raw footage or send us photos — we handle the rest, including monthly testing of 2–3 variations.' },
  { q: 'How fast can I go live?', a: '2–3 weeks from kickoff to a live website. Ads launch shortly after, once tracking and the page are confirmed working correctly.' },
  { q: 'What does missed-call protection do?', a: 'When a call goes unanswered, the system automatically sends an SMS to keep the conversation going and guide the lead toward booking — 24/7, with no extra effort from you.' },
  { q: 'Is there a contract?', a: 'Month-to-month, $1,500/month flat. No long-term lock-in.' },
  { q: 'What reporting do I get?', a: 'Every month: leads generated, cost per lead, lead source, and conversions — in plain numbers, not vague summaries.' },
  { q: 'Who is this for?', a: 'Businesses ready to invest consistently in lead generation, typically $2,000+/month combined (service fee + ad spend), and ready to move within the next few weeks.' },
];
---
<Layout seo={seo}>
<section class="bg-white py-16">
  <div class="container mx-auto px-6 max-w-3xl">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Frequently asked questions</h1>
    <p class="text-lg text-gray-600 mb-12">About the $1,500/mo website, ads, and lead recovery system.</p>
    <div class="space-y-4">
      {faqs.map((f) => (
        <details class="bg-gray-50 border border-gray-200 rounded-xl p-5 group">
          <summary class="cursor-pointer font-medium text-gray-900 flex justify-between items-center">
            {f.q}
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>
    <div class="mt-12 bg-gray-900 text-white rounded-xl p-8 text-center">
      <h2 class="text-2xl font-bold mb-3">Still have questions?</h2>
      <a href="/apply" class="inline-block mt-2 px-8 py-3 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">Get Started →</a>
    </div>
  </div>
</section>
</Layout>

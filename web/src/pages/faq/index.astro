---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: 'Why $2,500/mo if ad spend isn\'t included?', a: 'The $2,500 covers all our work: system installation, full management, creatives, continuous optimization, reporting, and direct access to me. Ad spend goes straight to Google or Meta — in accounts you own. We don\'t touch that money or mark it up. If you ever leave, everything stays with you.' },
  { q: 'How does the guarantee work exactly?', a: 'If in 30 days we don\'t generate more in booked jobs than you paid us — we work the next month free until the guarantee is met. The measurement is clear: booked jobs through the tracked number and reactivation replies with estimated value over $2,500. Everything in your dashboard — no disputes.' },
  { q: 'What do I need to contribute?', a: 'About 3 hours during initial setup for access and feedback. After that, you return or answer leads the system sends you within 24 hours, and spend 1 hour a month reviewing reporting. The point of the system is that it works without you on top of it.' },
  { q: 'When do I start spending on ads?', a: 'Week 3 or 4 — once your landing is optimized and tracking is confirmed working. The first 2 weeks the recovery phase works on what you already have (missed calls and your inactive customer list) without spending on ads. The goal: phase 1 revenue pays for the ad spend in phase 2.' },
  { q: 'Is there a long-term contract?', a: 'No. No setup fee. No cancellation penalty. If at any point the system doesn\'t make sense for your business, let us know and it\'s closed. No fees, no paperwork.' },
  { q: 'What type of business is this for?', a: 'Trades and home service businesses doing $1M–$3M in annual revenue in Western Canada: plumbing, HVAC, roofing, electrical, landscaping, house cleaning, pest control, auto repair, dental, chiropractic. You need an existing customer base and the ability to return leads within 24 hours.' },
  { q: 'What if my business is below $1M?', a: 'This specific system is designed for businesses with enough volume so that missed-call recovery and reactivation generate visible results fast. If you\'re below that level, the ROI may be lower — tell us in the form and we\'ll give you an honest answer.' },
  { q: 'Why only 1 client per week?', a: 'The system gets installed properly or it doesn\'t. Each client needs me to understand their business, their numbers, and their market. That can\'t be done in series. If this week\'s spot is taken, the next start is next week.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const seo = {
  title: 'FAQ — Revenue Recovery + Growth Program | BrandsBuilders',
  description: 'Answers to the most common questions about the $2,500/mo program: what\'s included, how the guarantee works, when ads turn on, and who qualifies.',
  canonical: 'https://brandsbuilders.ca/faq',
  schema: faqSchema,
};
---
<Layout seo={seo}>
<section class="bg-white py-16">
  <div class="container mx-auto px-6 max-w-3xl">

    <div class="mb-12">
      <p class="text-sm text-orange-600 font-semibold uppercase tracking-wider mb-3">FAQ</p>
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Frequently asked questions</h1>
      <p class="text-lg text-gray-600">About the Revenue Recovery + Growth Program — $2,500/mo.</p>
    </div>

    <div class="space-y-4">
      {faqs.map((f) => (
        <details class="bg-gray-50 border border-gray-200 rounded-xl p-5 group">
          <summary class="cursor-pointer font-semibold text-gray-900 flex justify-between items-center gap-4 text-sm">
            {f.q}
            <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-gray-600 text-sm leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>

    <div class="mt-12 bg-gray-900 text-white rounded-xl p-8 text-center">
      <h2 class="text-2xl font-bold mb-2">Still have questions?</h2>
      <p class="text-gray-400 text-sm mb-6">Apply and we'll respond personally within 24 hours — or book a call.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/apply" class="inline-flex px-7 py-3 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition text-sm">
          Apply to the program →
        </a>
        <a href="https://cal.com/brandsbuilders/30-min" target="_blank" rel="noopener noreferrer"
          class="inline-flex px-7 py-3 rounded-lg font-semibold text-white border border-gray-700 hover:border-gray-500 transition text-sm">
          Book a call
        </a>
      </div>
    </div>

  </div>
</section>
</Layout>

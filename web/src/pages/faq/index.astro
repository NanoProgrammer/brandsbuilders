---
import Layout from '../../layouts/Layout.astro';
const seo = {
  title: 'FAQ — Revenue Efficiency System | BrandsBuilders',
  description: 'Common questions about the Revenue Efficiency System for home services businesses.',
  canonical: 'https://brandsbuilders.ca/faq'
};
const faqs = [
  { q: 'What is the Revenue Efficiency System?', a: 'A done-for-you system with three components: missed-call protection (instant SMS to every missed call), show-up optimization (automated appointment reminders), and past client reactivation (one-time outreach to your database). It turns more inbound leads into booked jobs.' },
  { q: 'What does missed-call protection do?', a: 'When a customer calls and you can\'t answer, our system sends an instant SMS within seconds. It keeps the conversation alive, answers questions, and automatically guides the lead toward booking in your calendar — 24/7.' },
  { q: 'What is the Revenue Recovery Guarantee?', a: 'You will see a minimum of 5 recovered leads booked in your calendar within 30 days of going live — or your money back. No conditions.' },
  { q: 'How fast can I go live?', a: '2 weeks from qualification to live system. We handle all setup, integration, and testing.' },
  { q: 'Who is this for?', a: 'Home services businesses (HVAC, plumbing, restoration, roofing, pest control, garage door) generating $500K+ per year with real inbound call volume.' },
  { q: 'Do I have to manage anything?', a: 'No. We build, install, and manage the system. You just answer the phone when it rings and show up to jobs.' },
  { q: 'What does past client reactivation include?', a: 'A one-time email and SMS outreach to your past client list with a small free offer to get them back through the door — so you can upsell on-site. Quick revenue wins in the first 30 days.' },
  { q: 'Is there a contract?', a: 'Month-to-month. No long-term lock-in. The system pays for itself — you stay because it works.' },
  { q: 'What reporting do I get?', a: 'Monthly reporting on leads recovered, calls captured, appointments booked, and revenue impact.' },
];
---
<Layout seo={seo}>
<section class="bg-white py-16">
  <div class="container mx-auto px-6 max-w-3xl">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Frequently asked questions</h1>
    <p class="text-lg text-gray-600 mb-12">About the Revenue Efficiency System.</p>
    <div class="space-y-4">
      {faqs.map((f) => (
        <details class="bg-gray-50 border border-gray-200 rounded-xl p-5 group">
          <summary class="cursor-pointer font-medium text-gray-900 flex justify-between items-center">
            {f.q}
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>
    <div class="mt-12 bg-gray-900 text-white rounded-xl p-8 text-center">
      <h2 class="text-2xl font-bold mb-3">Still have questions?</h2>
      <a href="/apply" class="inline-block mt-2 px-8 py-3 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">Get in Touch →</a>
    </div>
  </div>
</section>
</Layout>
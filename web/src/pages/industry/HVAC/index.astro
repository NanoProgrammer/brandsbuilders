---
import Layout from '../../../layouts/Layout.astro';
const seo = { title: 'HVAC Revenue Efficiency System | BrandsBuilders', description: 'Missed-call protection, show-up optimization, and past client reactivation for HVAC companies. $1,000/mo. Live in 2 weeks.', canonical: 'https://brandsbuilders.ca/industry/hvac' };
---
<Layout seo={seo}>
<section class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-4xl">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md bg-blue-50 text-blue-700 text-sm font-medium mb-6">Industry · HVAC</div>
    <h1 class="text-4xl font-bold text-gray-900 leading-tight">Stop losing HVAC jobs to missed calls and no-shows.</h1>
    <p class="mt-6 text-lg text-gray-600 leading-relaxed max-w-3xl">Every missed call is a $300–$3,000 service call walking to your competitor. Our system captures those leads automatically, reminds customers about booked jobs, and reactivates past clients for seasonal maintenance.</p>
    <div class="mt-8"><a href="/apply" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-white bg-orange-600 hover:bg-orange-700 transition">Check If You Qualify →</a></div>
  </div>
</section>
<section class="bg-gray-50 py-16 border-y border-gray-200">
  <div class="container mx-auto px-6 max-w-4xl">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">Where HVAC revenue leaks</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white border border-gray-200 rounded-xl p-6"><p class="text-gray-700">Missed calls during busy hours go straight to voicemail — and competitors.</p></div>
      <div class="bg-white border border-gray-200 rounded-xl p-6"><p class="text-gray-700">Customers forget scheduled maintenance and no-show without reminders.</p></div>
      <div class="bg-white border border-gray-200 rounded-xl p-6"><p class="text-gray-700">Past customers with aging systems never get contacted for seasonal service.</p></div>
      <div class="bg-white border border-gray-200 rounded-xl p-6"><p class="text-gray-700">Dispatch gaps from cancellations stay unfilled.</p></div>
    </div>
  </div>
</section>
<section class="bg-gray-900 text-white py-16 text-center">
  <div class="container mx-auto px-6 max-w-3xl">
    <h2 class="text-3xl font-bold mb-4">$1,000/mo. Live in 2 weeks. 5 leads in 30 days or money back.</h2>
    <a href="/apply" class="inline-block mt-4 px-8 py-3.5 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">Check Qualification →</a>
  </div>
</section>
</Layout>
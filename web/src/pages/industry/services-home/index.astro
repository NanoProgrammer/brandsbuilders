---
import Layout from '../../../layouts/Layout.astro';
const seo = { title: 'Revenue Efficiency System for Home Services | BrandsBuilders', description: 'Missed-call protection, show-up optimization, and client reactivation for plumbing, restoration, roofing, pest control, and garage door companies.', canonical: 'https://brandsbuilders.ca/industry/services-home' };
---
<Layout seo={seo}>
<section class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-4xl">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md bg-orange-50 text-orange-700 text-sm font-medium mb-6">Home Services</div>
    <h1 class="text-4xl font-bold text-gray-900 leading-tight">Stop losing jobs to missed calls and no-shows.</h1>
    <p class="mt-6 text-lg text-gray-600 leading-relaxed max-w-3xl">We install a done-for-you system that captures missed calls via instant SMS, reduces no-shows with smart reminders, and reactivates past clients for quick revenue wins.</p>
    <div class="mt-8"><a href="/apply" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-white bg-orange-600 hover:bg-orange-700 transition">Check If You Qualify →</a></div>
  </div>
</section>
<section class="bg-gray-50 py-16 border-y border-gray-200">
  <div class="container mx-auto px-6 max-w-4xl">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">Industries we serve</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <a href="/industry/HVAC" class="bg-white border border-gray-200 rounded-xl p-5 hover:border-orange-300 transition"><h3 class="font-semibold text-gray-900">HVAC</h3><p class="text-gray-500 text-sm mt-1">Service calls + seasonal maintenance</p></a>
      <div class="bg-white border border-gray-200 rounded-xl p-5"><h3 class="font-semibold text-gray-900">Plumbing</h3><p class="text-gray-500 text-sm mt-1">Emergency + scheduled service</p></div>
      <div class="bg-white border border-gray-200 rounded-xl p-5"><h3 class="font-semibold text-gray-900">Restoration</h3><p class="text-gray-500 text-sm mt-1">Water, fire, mold jobs</p></div>
      <div class="bg-white border border-gray-200 rounded-xl p-5"><h3 class="font-semibold text-gray-900">Roofing</h3><p class="text-gray-500 text-sm mt-1">Inspections + repairs + installs</p></div>
      <div class="bg-white border border-gray-200 rounded-xl p-5"><h3 class="font-semibold text-gray-900">Pest Control</h3><p class="text-gray-500 text-sm mt-1">Recurring service + seasonal</p></div>
      <div class="bg-white border border-gray-200 rounded-xl p-5"><h3 class="font-semibold text-gray-900">Garage Door</h3><p class="text-gray-500 text-sm mt-1">Repair + installation</p></div>
    </div>
  </div>
</section>
<section class="bg-gray-900 text-white py-16 text-center">
  <div class="container mx-auto px-6 max-w-3xl">
    <h2 class="text-3xl font-bold mb-4">$1,000/mo. Live in 2 weeks. Guaranteed results.</h2>
    <a href="/apply" class="inline-block mt-4 px-8 py-3.5 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">Check Qualification →</a>
  </div>
</section>
</Layout>
---
import Layout from '../../layouts/Layout.astro';
const seo = { title: 'How It Works | BrandsBuilders', description: 'How the $1,500/mo website, ads, and lead recovery system gets built and launched.', canonical: 'https://brandsbuilders.ca/process' };
---
<Layout seo={seo}>
<section class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-4xl">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">How it works</h1>
    <p class="text-lg text-gray-600 mb-14">From application to a live system in 2–3 weeks.</p>
    <div class="space-y-10">
      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center text-orange-700 font-bold">1</div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-1">Apply &amp; fit check</h3>
          <p class="text-gray-600">You fill out the form. We confirm your business is ready for consistent ad spend and lead volume.</p>
        </div>
      </div>
      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center text-orange-700 font-bold">2</div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-1">Build the website</h3>
          <p class="text-gray-600">We design and build your high-conversion website, live in 2–3 weeks, with tracking and a dedicated phone number wired in.</p>
        </div>
      </div>
      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center text-orange-700 font-bold">3</div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-1">Launch ads &amp; missed-call protection</h3>
          <p class="text-gray-600">Campaigns go live on the platform that fits your business. Every missed call now triggers an automatic SMS recovery.</p>
        </div>
      </div>
      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center text-green-700 font-bold">4</div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-1">Test, report, and optimize</h3>
          <p class="text-gray-600">Every month: new creative variations tested, full reporting on leads, cost per lead, source, and conversions.</p>
        </div>
      </div>
    </div>
    <div class="mt-14 text-center">
      <a href="/apply" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-white bg-orange-600 hover:bg-orange-700 transition">Get Started →</a>
    </div>
  </div>
</section>
</Layout>

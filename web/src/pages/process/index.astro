---
import Layout from '../../layouts/Layout.astro';
const seo = { title: 'How It Works — Revenue Efficiency System | BrandsBuilders', description: 'How the Revenue Efficiency System is installed for your home services business in 2 weeks.', canonical: 'https://brandsbuilders.ca/process' };
---
<Layout seo={seo}>
<section class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-4xl">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">How it works</h1>
    <p class="text-lg text-gray-600 mb-14">From qualification to live system in 2 weeks.</p>
    <div class="space-y-10">
      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center text-orange-700 font-bold">1</div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-1">Qualification</h3>
          <p class="text-gray-600">You fill out the form. We confirm your industry, revenue, and call volume qualify for the system.</p>
        </div>
      </div>
      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center text-orange-700 font-bold">2</div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-1">Setup & Integration</h3>
          <p class="text-gray-600">We configure missed-call SMS, appointment reminders, and past client outreach. Connected to your phone system and calendar.</p>
        </div>
      </div>
      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center text-orange-700 font-bold">3</div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-1">Go Live</h3>
          <p class="text-gray-600">System goes live. Missed calls get instant SMS. Appointments get reminders. Past clients get reactivated.</p>
        </div>
      </div>
      <div class="flex gap-6 items-start">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center text-green-700 font-bold">4</div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-1">Monthly Reporting</h3>
          <p class="text-gray-600">Every month you see leads recovered, calls captured, and revenue impact. If you don't see 5 recovered leads in 30 days, you get your money back.</p>
        </div>
      </div>
    </div>
    <div class="mt-14 text-center">
      <a href="/apply" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-white bg-orange-600 hover:bg-orange-700 transition">Check If You Qualify →</a>
    </div>
  </div>
</section>
</Layout>
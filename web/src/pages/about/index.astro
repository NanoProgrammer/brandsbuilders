---
import Layout from "../../layouts/Layout.astro";
const seo = {
  title: "About — BrandsBuilders",
  description: "BrandsBuilders installs revenue efficiency systems for home services businesses across Western Canada.",
  canonical: "https://brandsbuilders.ca/about"
};
---
<Layout seo={seo}>
<section class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-4xl">
    <p class="text-sm text-gray-500 uppercase tracking-wider mb-4">About BrandsBuilders</p>
    <h1 class="text-4xl font-bold text-gray-900 leading-tight">
      We install revenue efficiency systems — not marketing campaigns.
    </h1>
    <p class="mt-6 text-lg text-gray-600 leading-relaxed max-w-3xl">
      BrandsBuilders helps home services businesses recover lost revenue from missed calls, no-shows, and inactive past clients — with systems that work automatically, 24/7.
    </p>
  </div>
</section>

<section class="bg-gray-50 py-16 border-y border-gray-200">
  <div class="container mx-auto px-6 max-w-4xl">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">Why we exist</h2>
    <div class="space-y-4 text-gray-600 text-lg leading-relaxed">
      <p>Most home services companies don't have a lead problem. They have a conversion problem — missed calls that never get answered, booked jobs that don't show up, and past clients who never hear from them again.</p>
      <p>We exist to fix those gaps with done-for-you systems that run in the background while you focus on the work.</p>
    </div>
  </div>
</section>

<section class="bg-white py-16">
  <div class="container mx-auto px-6 max-w-4xl">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">Who we work with</h2>
    <p class="text-gray-600 text-lg leading-relaxed mb-6">
      Home services businesses generating $500K+ per year with real inbound call volume and an existing client base.
    </p>
    <div class="grid sm:grid-cols-2 gap-3 text-gray-700">
      <div class="bg-gray-50 border border-gray-200 rounded-lg px-5 py-3 font-medium">HVAC</div>
      <div class="bg-gray-50 border border-gray-200 rounded-lg px-5 py-3 font-medium">Plumbing</div>
      <div class="bg-gray-50 border border-gray-200 rounded-lg px-5 py-3 font-medium">Restoration</div>
      <div class="bg-gray-50 border border-gray-200 rounded-lg px-5 py-3 font-medium">Roofing</div>
      <div class="bg-gray-50 border border-gray-200 rounded-lg px-5 py-3 font-medium">Pest Control</div>
      <div class="bg-gray-50 border border-gray-200 rounded-lg px-5 py-3 font-medium">Garage Door</div>
    </div>
  </div>
</section>

<section class="bg-gray-900 text-white py-16 text-center">
  <div class="container mx-auto px-6 max-w-3xl">
    <h2 class="text-3xl font-bold mb-4">Ready to recover lost revenue?</h2>
    <a href="/apply" class="inline-block mt-4 px-8 py-3.5 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">Check Qualification →</a>
  </div>
</section>
</Layout>
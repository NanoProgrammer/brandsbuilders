---
import Layout from '../../layouts/Layout.astro';

const seo = {
  title: 'About BrandsBuilders — Calgary Marketing for Home Service Businesses',
  description: 'BrandsBuilders is run by Santiago González from Calgary. We help plumbers, HVAC techs, roofers, and other trades stop losing customers to missed calls, dead customer lists, and marketing that doesn\'t produce real bookings.',
  canonical: 'https://brandsbuilders.ca/about'
};

const reviews = [
  { name: 'Heaven Artisan GF', tag: 'Local Guide', text: "He actually listens, understands the day-to-day challenges we face, and delivers solutions that are practical, efficient, and tailored — not generic. He doesn't just talk strategy, he executes." },
  { name: 'Abdul B.', tag: 'Local Guide', text: 'Great developer, straightforward. Clean layout and helped increase revenue for my business.' },
  { name: 'Jordan', tag: 'Local Guide', text: 'Was great working with Santiago. Would absolutely recommend 100%.' },
  { name: 'Justice Rayy', text: 'Local, friendly, and brings results over the expectation. Highly recommended.' },
];
---

<Layout seo={seo}>

  <!-- ═══════════════════════════════════════════
       WHO I AM
  ═══════════════════════════════════════════ -->
  <section class="bg-white py-20">
    <div class="container mx-auto px-6 max-w-4xl">

      <div class="grid md:grid-cols-2 gap-12 items-center">

        <!-- Text -->
        <div>
          <p class="text-sm text-orange-600 font-semibold uppercase tracking-wider mb-4">About BrandsBuilders</p>
          <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight mb-6">
            Hi, I'm Santiago.
          </h1>
          <div class="space-y-4 text-gray-600 text-lg leading-relaxed">
            <p>
              I'm an 18-year-old entrepreneur based in Calgary, AB, and the founder of BrandsBuilders. I started this business because I kept seeing the same problem: local home service companies were losing leads every day — not from bad work, but from a missed call here, a slow website there, a client list nobody ever followed up with.
            </p>
            <p>
              I've spent 3+ years building websites, running ad campaigns, and building systems for local businesses across Calgary. BrandsBuilders is the result of everything I've learned about what actually moves the needle for service companies.
            </p>
            <p>
              I work with a small number of businesses at a time so I can actually deliver — not just sell.
            </p>
          </div>
        </div>

        <!-- Photo placeholder -->
        <div class="flex justify-center md:justify-end">
          <div class="w-72 h-80 rounded-2xl bg-gray-100 border border-gray-200 flex items-center justify-center text-center p-6">
            <div>
              <div class="w-16 h-16 rounded-full bg-orange-100 text-orange-500 flex items-center justify-center mx-auto mb-3">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <p class="text-sm text-gray-400">Photo coming soon</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT WE DO
  ═══════════════════════════════════════════ -->
  <section class="bg-gray-50 py-16 border-y border-gray-200">
    <div class="container mx-auto px-6 max-w-4xl text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-5">What BrandsBuilders does</h2>
      <p class="text-xl text-gray-700 max-w-2xl mx-auto leading-relaxed font-medium">
        We help home service businesses stop losing customers through missed calls, inactive client lists, and underperforming marketing.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROOF
  ═══════════════════════════════════════════ -->
  <section class="bg-white py-20">
    <div class="container mx-auto px-6 max-w-4xl">

      <!-- stats -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 mb-16">
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-gray-900">10+</div>
          <div class="text-sm text-gray-500 mt-1">Websites built</div>
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-gray-900">3+ yrs</div>
          <div class="text-sm text-gray-500 mt-1">Building for local businesses</div>
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 text-center col-span-2 sm:col-span-1">
          <div class="text-3xl font-bold text-orange-600">Calgary</div>
          <div class="text-sm text-gray-500 mt-1">AB · Home base</div>
        </div>
      </div>

      <!-- reviews -->
      <h3 class="text-xl font-bold text-gray-900 mb-6">What clients say</h3>
      <div class="grid sm:grid-cols-2 gap-5">
        {reviews.map((r) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6">
            <div class="flex gap-0.5 text-yellow-400 mb-3">
              {Array.from({length: 5}).map(() => (
                <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.802 2.035a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.802-2.035a1 1 0 00-1.175 0L6.62 16.282c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.984 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-gray-700 text-sm leading-relaxed">"{r.text}"</p>
            <div class="mt-4 pt-3 border-t border-gray-200">
              <p class="font-semibold text-gray-900 text-sm">{r.name}</p>
              {r.tag && <p class="text-xs text-gray-500">{r.tag} · Google</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CTA
  ═══════════════════════════════════════════ -->
  <section class="bg-gray-900 text-white py-16 text-center">
    <div class="container mx-auto px-6 max-w-2xl">
      <h2 class="text-2xl sm:text-3xl font-bold mb-3">Ready to stop losing customers?</h2>
      <p class="text-gray-400 mb-8">Free for 30 days. Setup in 1–2 hours. No contracts.</p>
      <a href="/" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">
        Get Started Free →
      </a>
    </div>
  </section>

</Layout>

---
import Layout from '../../layouts/Layout.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Santiago González',
  jobTitle: 'Founder',
  worksFor: { '@id': 'https://brandsbuilders.ca/#business' },
  url: 'https://brandsbuilders.ca/about',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Calgary',
    addressRegion: 'AB',
    addressCountry: 'CA',
  },
};

const seo = {
  title: 'About BrandsBuilders — Revenue Recovery + Growth for Trades | Calgary',
  description: 'BrandsBuilders is run by Santiago González from Calgary. We install revenue recovery and growth systems for trades businesses doing $1M–$3M — so they stop losing money to missed calls and inactive customer lists.',
  canonical: 'https://brandsbuilders.ca/about',
  schema: personSchema,
};

const reviews = [
  { name: 'Heaven Artisan GF', tag: 'Local Guide', text: "He actually listens, understands the day-to-day challenges we face, and delivers solutions that are practical, efficient, and tailored — not generic. He doesn't just talk strategy, he executes." },
  { name: 'Abdul B.', tag: 'Local Guide', text: 'Great developer, straightforward. Clean layout and helped increase revenue for my business.' },
  { name: 'Jordan', tag: 'Local Guide', text: 'Was great working with Santiago. Would absolutely recommend 100%.' },
  { name: 'Justice Rayy', text: 'Local, friendly, and brings results over the expectation. Highly recommended.' },
];
---

<Layout seo={seo}>

  <!-- WHO I AM -->
  <section class="bg-white py-20">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-sm text-orange-600 font-semibold uppercase tracking-wider mb-4">About BrandsBuilders</p>
          <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight mb-6">
            Hola, soy Santiago.
          </h1>
          <div class="space-y-4 text-gray-600 text-lg leading-relaxed">
            <p>
              Tengo 18 años, soy de Calgary, AB, y fundé BrandsBuilders porque veía el mismo problema repetirse: negocios de trades con buen trabajo y buena reputación — perdiendo clientes todos los días por una llamada sin contestar, un cliente que no volvió, o marketing que no producía bookings reales.
            </p>
            <p>
              Llevo 3+ años construyendo sistemas digitales para negocios locales: websites, campañas de ads, reactivación de clientes, tracking. BrandsBuilders es la versión destilada de todo lo que aprendí sobre qué mueve la aguja — y qué no — para una empresa de servicios que quiere escalar.
            </p>
            <p>
              Trabajo con un número pequeño de clientes a la vez para poder entregar de verdad. No solo vender.
            </p>
          </div>
        </div>

        <!-- Offer summary -->
        <div class="space-y-4">
          <div class="bg-gray-50 border border-gray-200 rounded-xl p-6">
            <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3">Lo que hace BrandsBuilders</p>
            <p class="text-gray-900 font-semibold text-lg leading-snug mb-4">
              Revenue Recovery + Growth para trades haciendo $1M–$3M en revenue anual.
            </p>
            <ul class="space-y-2">
              {[
                'Sistema de recuperación de llamadas perdidas',
                'Campañas de reactivación de clientes inactivos',
                'Gestión de ads Google / Meta',
                'Optimización del sitio y tracking real',
                'Dashboard con cada lead y su valor',
              ].map(item => (
                <li class="flex items-start gap-2.5 text-sm text-gray-700">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <div class="mt-5 pt-4 border-t border-gray-200">
              <span class="text-2xl font-bold text-gray-900">$2,500</span><span class="text-gray-500">/mes · sin setup fee · sin contrato</span>
            </div>
          </div>

          <div class="bg-gray-900 text-white rounded-xl p-5 text-sm">
            <p class="font-semibold text-orange-400 text-xs uppercase tracking-wider mb-2">La garantía</p>
            <p class="text-gray-300 leading-relaxed">Si en 30 días no te genero más en booked jobs que lo que me pagas — trabajo gratis hasta que se cumpla.</p>
          </div>

          <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 text-sm text-gray-600">
            <span class="font-semibold text-gray-900">Acceso directo:</span> Mi número personal, respuesta en menos de 24h, lunes a lunes. Sin tickets, sin chatbot.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="bg-gray-50 py-14 border-y border-gray-200">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
        <div class="bg-white border border-gray-200 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-gray-900">10+</div>
          <div class="text-sm text-gray-500 mt-1">Websites built</div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-gray-900">3+ yrs</div>
          <div class="text-sm text-gray-500 mt-1">Building for local businesses</div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-orange-600">Calgary</div>
          <div class="text-sm text-gray-500 mt-1">AB · Home base</div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-gray-900">1/sem</div>
          <div class="text-sm text-gray-500 mt-1">Capacidad de onboarding</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-white py-20">
    <div class="container mx-auto px-6 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Qué dicen los clientes</h2>
      <div class="grid sm:grid-cols-2 gap-5">
        {reviews.map((r) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6">
            <div class="flex gap-0.5 text-yellow-400 mb-3">
              {Array.from({length: 5}).map(() => (
                <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.802 2.035a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.802-2.035a1 1 0 00-1.175 0L6.62 16.282c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.984 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-gray-700 text-sm leading-relaxed">"{r.text}"</p>
            <div class="mt-4 pt-3 border-t border-gray-200">
              <p class="font-semibold text-gray-900 text-sm">{r.name}</p>
              {r.tag && <p class="text-xs text-gray-500">{r.tag} · Google</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-900 text-white py-16 text-center">
    <div class="container mx-auto px-6 max-w-2xl">
      <h2 class="text-2xl sm:text-3xl font-bold mb-3">¿Tu negocio califica?</h2>
      <p class="text-gray-400 mb-8">Solo trabajo con trades haciendo $1M–$3M. Si ese eres tú, aplica — 1 spot disponible esta semana.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/apply" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">
          Aplicar al programa →
        </a>
        <a href="https://cal.com/brandsbuilders/30-min" target="_blank" rel="noopener noreferrer"
          class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-white border border-gray-700 hover:border-gray-500 transition">
          Hablar primero
        </a>
      </div>
    </div>
  </section>

</Layout>

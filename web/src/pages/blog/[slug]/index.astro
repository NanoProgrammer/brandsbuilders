---
import Layout from '../../../layouts/Layout.astro';
import { POSTS } from '../../../data/posts.js';
export function getStaticPaths() { return Object.keys(POSTS).map(slug => ({ params: { slug } })); }
const { slug } = Astro.params;
const post = POSTS[slug];
if (!post) return Astro.redirect('/404');
const seo = { title: `${post.title} — BrandsBuilders`, description: post.excerpt, canonical: `https://brandsbuilders.ca/blog/${slug}` };
---
<Layout seo={seo}>
<section class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-3xl">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-gray-700">Home</a> / <a href="/blog" class="hover:text-gray-700">Insights</a></nav>
    <div class="flex items-center gap-3 text-sm text-gray-500 mb-4">
      <span class="px-2 py-0.5 rounded bg-gray-100 text-xs font-medium">{post.category}</span>
      <span>{post.readTime}</span>
    </div>
    <h1 class="text-4xl font-bold text-gray-900 mb-4">{post.title}</h1>
    <p class="text-xl text-gray-600 mb-10">{post.excerpt}</p>
    <article class="prose prose-gray max-w-none"><div set:html={post.content} /></article>
    <div class="mt-16 bg-gray-900 text-white rounded-xl p-8 text-center">
      <h3 class="text-2xl font-bold mb-3">Ready for a system that actually converts?</h3>
      <a href="/apply" class="inline-block mt-2 px-8 py-3 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">Get Started →</a>
    </div>
  </div>
</section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { POSTS } from '../../data/posts.js';
const blogPosts = Object.entries(POSTS).map(([slug, post]) => ({ slug, ...post }));
const seo = { title: 'Insights — BrandsBuilders', description: 'Frameworks on acquisition, conversion, and growth for service businesses.', canonical: 'https://brandsbuilders.ca/blog' };
---
<Layout seo={seo}>
<section class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-3xl">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Insights</h1>
    <p class="text-lg text-gray-600 mb-14">Frameworks on how acquisition actually works for service businesses.</p>
    <div class="space-y-10">
      {blogPosts.map((post) => (
        <article>
          <div class="flex items-center gap-3 text-sm text-gray-500 mb-2">
            <span class="px-2 py-0.5 rounded bg-gray-100 text-gray-600 text-xs font-medium">{post.category}</span>
            <span>{post.readTime}</span>
          </div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">
            <a href={`/blog/${post.slug}`} class="hover:text-orange-600 transition">{post.title}</a>
          </h2>
          <p class="text-gray-600">{post.excerpt}</p>
          <a href={`/blog/${post.slug}`} class="inline-block mt-3 text-sm font-medium text-orange-600 hover:text-orange-700">Read article →</a>
          <div class="mt-8 h-px bg-gray-200"></div>
        </article>
      ))}
    </div>
  </div>
</section>
</Layout>
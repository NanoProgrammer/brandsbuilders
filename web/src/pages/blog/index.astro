---
import Layout from '../../layouts/Layout.astro';
import { POSTS } from '../../data/posts.js';

const seo = {
  title: 'Insights — BrandsBuilders',
  description: 'Practical frameworks on lead generation, missed-call recovery, web design, reactivation, and growth for home service businesses in Western Canada.',
  canonical: 'https://brandsbuilders.ca/blog',
};

const allPosts = Object.entries(POSTS)
  .map(([slug, post]) => ({ slug, ...post }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const offerGroups = [
  { key: 'general',      label: 'Business Fundamentals',      color: 'bg-gray-100 text-gray-700 border-gray-200',    dot: 'bg-gray-500' },
  { key: 'missed-call',  label: 'Missed-Call Recovery',       color: 'bg-orange-50 text-orange-700 border-orange-200', dot: 'bg-orange-500' },
  { key: 'web-design',   label: 'Web Design',                 color: 'bg-blue-50 text-blue-700 border-blue-200',     dot: 'bg-blue-500' },
  { key: 'reactivation', label: 'Reactivation Campaigns',     color: 'bg-violet-50 text-violet-700 border-violet-200', dot: 'bg-violet-500' },
  { key: 'membership',   label: 'Growth Systems & Membership', color: 'bg-emerald-50 text-emerald-700 border-emerald-200', dot: 'bg-emerald-500' },
];

const awarenessOrder = ['unaware', 'pain-aware', 'problem-aware', 'solution-aware', 'product-aware'];
const awarenessLabels: Record<string, string> = {
  'unaware':        'Foundations',
  'pain-aware':     'Problem Diagnosis',
  'problem-aware':  'Root Causes',
  'solution-aware': 'Frameworks & Options',
  'product-aware':  'How It Works',
};
---

<Layout seo={seo}>

  <!-- Header -->
  <section class="bg-white pt-16 pb-10 border-b border-gray-200">
    <div class="container mx-auto px-6 max-w-4xl">
      <p class="text-sm font-semibold text-orange-600 uppercase tracking-wider mb-3">Insights</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4">Practical frameworks for home service businesses.</h1>
      <p class="text-lg text-gray-600 max-w-2xl">
        Articles organized by topic and awareness level — from fundamentals to exact how-to guidance on each service we offer.
      </p>
    </div>
  </section>

  <!-- Content by offer group -->
  <section class="bg-white py-16">
    <div class="container mx-auto px-6 max-w-4xl space-y-20">

      {offerGroups.map(group => {
        const groupPosts = allPosts.filter(p => (p.offer ?? 'general') === group.key);
        if (groupPosts.length === 0) return null;

        const byAwareness = awarenessOrder
          .map(level => ({
            level,
            label: awarenessLabels[level],
            posts: groupPosts.filter(p => p.awarenessLevel === level),
          }))
          .filter(a => a.posts.length > 0);

        return (
          <div>
            <!-- Group header -->
            <div class="flex items-center gap-3 mb-8">
              <span class={`w-3 h-3 rounded-full shrink-0 ${group.dot}`}></span>
              <h2 class="text-2xl font-bold text-gray-900">{group.label}</h2>
              <span class={`ml-auto text-xs font-medium px-2.5 py-1 rounded-full border ${group.color}`}>{groupPosts.length} articles</span>
            </div>

            <!-- Awareness-level sub-groups -->
            <div class="space-y-10">
              {byAwareness.map(aw => (
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-4">{aw.label}</p>
                  <div class="space-y-5">
                    {aw.posts.map(post => (
                      <article class="flex gap-5 group">
                        <div class="pt-1 shrink-0">
                          <div class={`w-2 h-2 rounded-full mt-1.5 ${group.dot} opacity-60`}></div>
                        </div>
                        <div>
                          <h3 class="font-semibold text-gray-900 group-hover:text-orange-600 transition leading-snug">
                            <a href={`/blog/${post.slug}`}>{post.title}</a>
                          </h3>
                          <p class="text-sm text-gray-600 mt-1 leading-relaxed">{post.excerpt}</p>
                          <div class="flex items-center gap-3 mt-2 text-xs text-gray-400">
                            <span>{post.readTime}</span>
                            <span>{new Date(post.date).toLocaleDateString('en-CA', { month: 'short', year: 'numeric' })}</span>
                          </div>
                        </div>
                      </article>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-50 border-t border-gray-200 py-14">
    <div class="container mx-auto px-6 max-w-3xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Ready to put this into practice?</h2>
      <p class="text-gray-600 mb-7">Start with missed-call recovery — free for 30 days, takes 1–2 hours to set up, and shows results immediately.</p>
      <a href="/apply" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-white bg-orange-600 hover:bg-orange-700 transition">
        Start Free Trial →
      </a>
    </div>
  </section>

</Layout>

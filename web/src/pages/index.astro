---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhyItMatters from '../components/WhyItMatters.astro';
import SystemBlocks from '../components/SystemBlocks.astro';
import ProofPreview from '../components/ProofPreview.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQPreview from '../components/FAQPreview.astro';
import ApplyCTA from '../components/ApplyCTA.astro';

const seo = {
  title: 'BrandsBuilders — Website + Ads + Lead Recovery, $1,500/mo',
  description: 'A high-conversion website, Google or Meta Ads management, and missed-call protection, all under one flat monthly fee. Live in 2–3 weeks.',
  canonical: 'https://brandsbuilders.ca',
  ogImage: '/og.webp'
};
---
<Layout seo={seo}>
  <Hero />
  <WhyItMatters />
  <SystemBlocks />
  <ProofPreview />
  <Testimonials />
  <FAQPreview />
  <ApplyCTA />
</Layout>

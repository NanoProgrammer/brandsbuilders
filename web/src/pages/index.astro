---
import Layout from '../layouts/Layout.astro';

const seo = {
  title: 'Stop Losing Leads to Missed Calls — BrandsBuilders',
  description: 'Every missed call is a customer going to your competitor. We automatically text back every missed call so you never lose a lead again — free for 30 days.',
  canonical: 'https://brandsbuilders.ca',
  ogImage: '/og.webp'
};
---

<Layout seo={seo}>

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="bg-white pt-14 pb-16 lg:pb-20">
    <div class="container mx-auto px-6 max-w-4xl text-center">

      <!-- stat pill -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-orange-50 border border-orange-200 text-orange-700 text-sm font-semibold mb-8">
        <span class="w-2 h-2 rounded-full bg-orange-500 shrink-0"></span>
        The average home service business misses 30%+ of incoming calls
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 leading-[1.1] tracking-tight">
        Every Missed Call Is a Customer
        <span class="text-orange-600"> Going to Your Competitor.</span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
        We automatically text back every missed call so you never lose a lead again —
        <strong class="text-gray-800">free for 30 days.</strong>
      </p>

      <div class="mt-10">
        <a href="/apply"
          class="inline-flex px-9 py-4 rounded-lg font-semibold text-white bg-orange-600 hover:bg-orange-700 transition text-lg shadow-sm">
          Get Started Free →
        </a>
      </div>

      <p class="mt-5 text-sm text-gray-500">
        No contract · No credit card required · Setup in 1–2 hours
      </p>

      <!-- ROI stat row -->
      <div class="mt-14 grid grid-cols-1 sm:grid-cols-3 gap-5 max-w-3xl mx-auto">
        <div class="bg-gray-50 border border-gray-200 rounded-xl px-6 py-5 text-center">
          <div class="text-3xl font-bold text-gray-900">30%+</div>
          <div class="text-sm text-gray-500 mt-1">of calls go unanswered</div>
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded-xl px-6 py-5 text-center">
          <div class="text-3xl font-bold text-orange-600">&lt; 60 sec</div>
          <div class="text-sm text-gray-500 mt-1">auto-text response time</div>
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded-xl px-6 py-5 text-center">
          <div class="text-3xl font-bold text-gray-900">$500+</div>
          <div class="text-sm text-gray-500 mt-1">avg job value recovered</div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HOW IT WORKS
  ═══════════════════════════════════════════ -->
  <section class="bg-gray-50 py-20 border-y border-gray-200">
    <div class="container mx-auto px-6 max-w-4xl">

      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">How it works</h2>
        <p class="mt-3 text-lg text-gray-600">Three steps. Zero effort from you.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">

        <div class="bg-white rounded-xl border border-gray-200 p-7 relative">
          <div class="w-10 h-10 rounded-full bg-orange-100 text-orange-600 font-bold flex items-center justify-center text-lg mb-5">1</div>
          <h3 class="font-bold text-gray-900 text-lg mb-2">We set up your tracked number</h3>
          <p class="text-gray-600 leading-relaxed text-sm">
            We provision a dedicated phone number for your business in 1–2 hours. No tech work on your end — we handle everything.
          </p>
          <div class="mt-4 text-xs text-orange-600 font-medium">1–2 hours · zero effort from you</div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-7 relative">
          <div class="w-10 h-10 rounded-full bg-orange-100 text-orange-600 font-bold flex items-center justify-center text-lg mb-5">2</div>
          <h3 class="font-bold text-gray-900 text-lg mb-2">Missed call triggers an auto-text</h3>
          <p class="text-gray-600 leading-relaxed text-sm">
            The moment a call goes unanswered, our system sends a personalized SMS to that lead within seconds — keeping them engaged before they dial a competitor.
          </p>
          <div class="mt-4 text-xs text-orange-600 font-medium">Fires in under 60 seconds · 24/7</div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-7 relative">
          <div class="w-10 h-10 rounded-full bg-orange-100 text-orange-600 font-bold flex items-center justify-center text-lg mb-5">3</div>
          <h3 class="font-bold text-gray-900 text-lg mb-2">The lead responds and books</h3>
          <p class="text-gray-600 leading-relaxed text-sm">
            They reply to the SMS, book an appointment, and you recover revenue you would have lost. We only charge for bookings saved — no booking, no charge.
          </p>
          <div class="mt-4 text-xs text-orange-600 font-medium">$25 per booking · only if it works</div>
        </div>

      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROOF / RESULTS
  ═══════════════════════════════════════════ -->
  <section class="bg-white py-20">
    <div class="container mx-auto px-6 max-w-4xl">

      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Real results from real businesses</h2>
        <p class="mt-3 text-lg text-gray-600">We've built and grown local businesses across Calgary.</p>
      </div>

      <!-- Google review highlights -->
      <div class="grid sm:grid-cols-3 gap-6 mb-12">
        <div class="bg-gray-50 rounded-xl border border-gray-200 p-6">
          <div class="flex gap-0.5 text-yellow-400 mb-3">
            {Array.from({length: 5}).map(() => (
              <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.802 2.035a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.802-2.035a1 1 0 00-1.175 0L6.62 16.282c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.984 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-gray-700 text-sm leading-relaxed">
            "Clean layout and helped increase revenue for my business."
          </p>
          <div class="mt-4 pt-3 border-t border-gray-200 text-xs">
            <span class="font-semibold text-gray-900">Abdul B.</span>
            <span class="text-gray-500 ml-1">· Google Review</span>
          </div>
        </div>

        <div class="bg-gray-50 rounded-xl border border-gray-200 p-6">
          <div class="flex gap-0.5 text-yellow-400 mb-3">
            {Array.from({length: 5}).map(() => (
              <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.802 2.035a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.802-2.035a1 1 0 00-1.175 0L6.62 16.282c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.984 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-gray-700 text-sm leading-relaxed">
            "He actually listens, understands the day-to-day challenges we face, and delivers solutions that are practical, efficient, and tailored — not generic."
          </p>
          <div class="mt-4 pt-3 border-t border-gray-200 text-xs">
            <span class="font-semibold text-gray-900">Heaven Artisan GF</span>
            <span class="text-gray-500 ml-1">· Google Review</span>
          </div>
        </div>

        <div class="bg-gray-50 rounded-xl border border-gray-200 p-6">
          <div class="flex gap-0.5 text-yellow-400 mb-3">
            {Array.from({length: 5}).map(() => (
              <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.802 2.035a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.802-2.035a1 1 0 00-1.175 0L6.62 16.282c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.984 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-gray-700 text-sm leading-relaxed">
            "Local, friendly, and brings results over the expectation. Highly recommended."
          </p>
          <div class="mt-4 pt-3 border-t border-gray-200 text-xs">
            <span class="font-semibold text-gray-900">Justice Rayy</span>
            <span class="text-gray-500 ml-1">· Google Review</span>
          </div>
        </div>
      </div>

      <!-- Website portfolio tease -->
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-7 text-center">
        <p class="text-sm text-gray-500 uppercase tracking-wider font-medium mb-1">10+ websites built</p>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Refresh Exteriors · Artilate · GrillsGuard · Kelly & Sons YYC</h3>
        <p class="text-gray-600 text-sm mb-5">Home service and local businesses across Calgary — built from scratch, optimized to convert.</p>
        <a href="/proof" class="text-orange-600 hover:text-orange-700 font-medium text-sm transition">See all case studies →</a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       OBJECTION KILLERS
  ═══════════════════════════════════════════ -->
  <section class="bg-gray-50 py-20 border-y border-gray-200">
    <div class="container mx-auto px-6 max-w-3xl">

      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900">You probably have a few questions</h2>
      </div>

      <div class="space-y-4">

        <details class="bg-white border border-gray-200 rounded-xl p-6 group">
          <summary class="cursor-pointer font-semibold text-gray-900 flex justify-between items-center gap-4">
            What does it cost?
            <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            Completely free for 30 days. After that, <strong>$25 per booking saved</strong>. If we don't recover a booking for you, you don't pay anything. No booking = no charge.
          </p>
        </details>

        <details class="bg-white border border-gray-200 rounded-xl p-6 group">
          <summary class="cursor-pointer font-semibold text-gray-900 flex justify-between items-center gap-4">
            Do I need to change my phone number?
            <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            No. We set up a dedicated tracking number that forwards calls to your existing number. Your customers call the same number, you answer on your same phone.
          </p>
        </details>

        <details class="bg-white border border-gray-200 rounded-xl p-6 group">
          <summary class="cursor-pointer font-semibold text-gray-900 flex justify-between items-center gap-4">
            How long does setup take?
            <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            1–2 hours from the time you sign up. We handle all the configuration — you just tell us your business name, current phone number, and confirm the SMS message we draft for you.
          </p>
        </details>

        <details class="bg-white border border-gray-200 rounded-xl p-6 group">
          <summary class="cursor-pointer font-semibold text-gray-900 flex justify-between items-center gap-4">
            Is there a contract?
            <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-gray-600 leading-relaxed">
            No. Cancel anytime. After the free 30 days, you only pay for bookings we actually recover. If it's not working for you, just let us know and we remove the system — no fees, no paperwork.
          </p>
        </details>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FINAL CTA
  ═══════════════════════════════════════════ -->
  <section class="bg-gray-900 text-white py-20">
    <div class="container mx-auto px-6 max-w-3xl text-center">

      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        Stop letting missed calls become your competitor's customers.
      </h2>
      <p class="text-gray-400 text-lg mb-10 max-w-xl mx-auto">
        Free for 30 days. Setup in 1–2 hours. No contracts.
      </p>

      <a href="/apply"
        class="inline-flex px-9 py-4 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition text-lg">
        Get Started Free →
      </a>

      <p class="mt-5 text-sm text-gray-400">
        Or book a quick 15-minute call — we'll set everything up for you.
      </p>

    </div>
  </section>

</LandingLayout>

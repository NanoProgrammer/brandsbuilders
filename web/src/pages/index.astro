---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhyItMatters from '../components/WhyItMatters.astro';
import SystemBlocks from '../components/SystemBlocks.astro';
import ProofPreview from '../components/ProofPreview.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQPreview from '../components/FAQPreview.astro';
import ApplyCTA from '../components/ApplyCTA.astro';

const seo = {
  title: 'BrandsBuilders — Revenue Efficiency System for Home Services',
  description: 'We install a missed-call and lead conversion system that turns more inbound leads into booked jobs. Live in 2 weeks. $1,000/mo. 5 leads in 30 days or money back.',
  canonical: 'https://brandsbuilders.ca',
  ogImage: '/og.webp'
};
---
<Layout seo={seo}>
  <Hero />
  <WhyItMatters />
  <SystemBlocks />
  <ProofPreview />
  <Testimonials />
  <FAQPreview />
  <ApplyCTA />
</Layout>
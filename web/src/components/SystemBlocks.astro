---
const items = [
  {
    n: '1',
    title: 'High-Conversion Website',
    desc: 'A full build or rebuild focused on turning visitors into leads — not just looking good. Live in 2–3 weeks.',
    color: 'orange'
  },
  {
    n: '2',
    title: 'Google Ads or Meta Ads',
    desc: 'One platform, run for you: campaigns, targeting, copy, and static creatives. We pick the platform that fits your business.',
    color: 'blue'
  },
  {
    n: '3',
    title: 'Basic Creative Testing',
    desc: '2–3 ad variations tested every month. We script and edit — you just record the raw footage or send photos.',
    color: 'violet'
  },
  {
    n: '4',
    title: 'Dedicated Phone Number',
    desc: 'Every lead that comes from your marketing is tracked and attributed. No more guessing where customers came from.',
    color: 'emerald'
  },
  {
    n: '5',
    title: 'Missed-Call Protection',
    desc: 'A missed call automatically triggers an SMS that keeps the conversation alive and recovers the lead — 24/7.',
    color: 'rose'
  },
  {
    n: '6',
    title: 'Monthly Reporting',
    desc: 'Leads generated, cost per lead, source, and conversions — every month, in plain numbers.',
    color: 'amber'
  },
];

const colorMap: Record<string, string> = {
  orange: 'bg-orange-100 text-orange-600',
  blue: 'bg-blue-100 text-blue-700',
  violet: 'bg-violet-100 text-violet-700',
  emerald: 'bg-emerald-100 text-emerald-700',
  rose: 'bg-rose-100 text-rose-700',
  amber: 'bg-amber-100 text-amber-700',
};
---
<section id="offer" class="bg-white py-20">
  <div class="container mx-auto px-6 max-w-5xl">

    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
        One offer. Everything you need to grow.
      </h2>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
        No tiers, no upsells, no confusing packages. Here's exactly what's included.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {items.map((item) => (
        <div class="bg-white rounded-xl border border-gray-200 p-7 hover:border-orange-200 transition">
          <div class={`flex-shrink-0 w-12 h-12 rounded-xl ${colorMap[item.color]} flex items-center justify-center font-bold text-lg mb-4`}>
            {item.n}
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
          <p class="text-gray-600 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>

    <!-- Pricing box -->
    <div class="mt-14 bg-gray-900 text-white rounded-xl p-8 md:p-10 text-center">
      <div class="text-sm font-medium text-gray-400 uppercase tracking-wider mb-2">Flat monthly fee</div>
      <div class="text-5xl font-bold mb-2">$1,500<span class="text-xl font-normal text-gray-400">/mo</span></div>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">
        Covers the website, ad management, creative testing, tracked number, missed-call protection, and monthly reporting.
      </p>
      <a href="/apply" class="inline-flex px-8 py-3.5 rounded-lg font-semibold text-gray-900 bg-white hover:bg-gray-100 transition">
        Get Started →
      </a>
      <div class="mt-6 inline-flex items-center gap-2 text-sm text-gray-300 bg-white/10 px-4 py-2 rounded-lg max-w-xl">
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Ad spend is billed directly to you (not included in the $1,500). We recommend $500–$1,500/mo to start.
      </div>
    </div>

  </div>
</section>

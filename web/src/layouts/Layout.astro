---
export interface Props {
  seo: {
    title: string;
    description: string;
    canonical?: string;
    ogImage?: string;
    noindex?: boolean;
    schema?: Record<string, unknown> | Record<string, unknown>[];
  };
  hideNavigation?: boolean;
}
const { seo, hideNavigation = false } = Astro.props;

import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const canonicalUrl = seo.canonical ?? `https://brandsbuilders.ca${Astro.url.pathname}`;
const ogImage = `https://brandsbuilders.ca${seo.ogImage ?? '/og.webp'}`;

const baseSchema: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': 'https://brandsbuilders.ca/#business',
    name: 'BrandsBuilders',
    url: 'https://brandsbuilders.ca',
    logo: 'https://brandsbuilders.ca/logo.webp',
    image: 'https://brandsbuilders.ca/og.webp',
    email: 'admin@brandsbuilders.ca',
    description: 'BrandsBuilders helps home service businesses in Western Canada generate more leads through missed-call recovery, custom web design, reactivation campaigns, and full-service marketing.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Calgary',
      addressRegion: 'AB',
      addressCountry: 'CA',
    },
    areaServed: [
      { '@type': 'City', name: 'Calgary', containedInPlace: { '@type': 'AdministrativeArea', name: 'Alberta' } },
      { '@type': 'City', name: 'Edmonton', containedInPlace: { '@type': 'AdministrativeArea', name: 'Alberta' } },
      { '@type': 'City', name: 'Vancouver', containedInPlace: { '@type': 'AdministrativeArea', name: 'British Columbia' } },
      { '@type': 'City', name: 'Surrey', containedInPlace: { '@type': 'AdministrativeArea', name: 'British Columbia' } },
      { '@type': 'City', name: 'Red Deer', containedInPlace: { '@type': 'AdministrativeArea', name: 'Alberta' } },
      { '@type': 'City', name: 'Lethbridge', containedInPlace: { '@type': 'AdministrativeArea', name: 'Alberta' } },
      { '@type': 'City', name: 'Kelowna', containedInPlace: { '@type': 'AdministrativeArea', name: 'British Columbia' } },
      { '@type': 'City', name: 'Burnaby', containedInPlace: { '@type': 'AdministrativeArea', name: 'British Columbia' } },
    ],
    priceRange: '$$',
    knowsAbout: ['Missed Call Recovery', 'Web Design', 'Customer Reactivation', 'Google Ads', 'Digital Marketing', 'Home Service Marketing'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': 'https://brandsbuilders.ca/#website',
    url: 'https://brandsbuilders.ca',
    name: 'BrandsBuilders',
    publisher: { '@id': 'https://brandsbuilders.ca/#business' },
  },
];

const pageSchema = seo.schema
  ? (Array.isArray(seo.schema) ? seo.schema : [seo.schema])
  : [];

const allSchema = [...baseSchema, ...pageSchema];
---

<!DOCTYPE html>
<html lang="en-CA" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{seo.title}</title>
  <meta name="description" content={seo.description} />
  <link rel="canonical" href={canonicalUrl} />
  {seo.noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="BrandsBuilders" />
  <meta property="og:locale" content="en_CA" />
  <meta property="og:title" content={seo.title} />
  <meta property="og:description" content={seo.description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="BrandsBuilders — Marketing for Home Service Businesses" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@brandsbuilders" />
  <meta name="twitter:title" content={seo.title} />
  <meta name="twitter:description" content={seo.description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(allSchema)} />

  <!-- Font -->
  <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin />
  <style is:inline>
    @font-face {
      font-family: 'Inter';
      src: url('/fonts/Inter-Variable.woff2') format('woff2');
      font-weight: 100 900;
      font-display: swap;
    }
    body { font-family: 'Inter', system-ui, sans-serif; }
  </style>

  <link rel="icon" href="/icono.ico" />
</head>

<!-- Analytics (deferred) -->
<script>
  window.addEventListener('load', () => {
    const s = document.createElement('script');
    s.src = 'https://www.googletagmanager.com/gtag/js?id=G-WXEQQW4KHT';

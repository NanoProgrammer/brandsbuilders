<noscript><img height="1" width="1" src="https://www.facebook.com/tr?id=820302531124359&ev=PageView&noscript=1"/></noscript>

<body class="bg-white text-gray-800 overflow-x-hidden">
  {!hideNavigation && <Navigation />}
  <main class={hideNavigation ? "" : "pt-16 sm:pt-20"}>
    <slot />
  </main>
  <Footer />
